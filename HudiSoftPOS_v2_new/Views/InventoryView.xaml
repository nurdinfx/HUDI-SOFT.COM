<UserControl x:Class="HudiSoftPOS.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:HudiSoftPOS.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1366">
    <Grid Background="#F8FAFB">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Page Title -->
                <RowDefinition Height="Auto"/> <!-- Search & Filters -->
                <RowDefinition Height="*"/>    <!-- Data Grid / List -->
            </Grid.RowDefinitions>

            <!-- Header Section -->
            <Border Grid.Row="0" Background="White" CornerRadius="16" BorderBrush="#E0E0E0" BorderThickness="1" Padding="25" Margin="0,0,0,25">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Inventory" FontSize="28" FontWeight="SemiBold" Foreground="#212121"/>
                        <TextBlock Text="{Binding TotalProductCount, StringFormat='{}{0} Products'}" FontSize="14" FontWeight="Medium" Foreground="#757575" Margin="0,5,0,0"/>
                    </StackPanel>
                    <Button Command="{Binding OpenAddProductCommand}" Content="+ Add Product" HorizontalAlignment="Right" VerticalAlignment="Center" 
                            materialDesign:ButtonAssist.CornerRadius="8" Padding="20,0" Height="45" FontSize="14" FontWeight="Bold" Background="#1B60F5" Foreground="White" BorderThickness="0"/>
                </Grid>
            </Border>

            <!-- Filter Strip -->
            <Border Grid.Row="1" Margin="0,0,0,25" Background="White" CornerRadius="12" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Search Bar -->
                    <Border Grid.Column="0" CornerRadius="8" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,15,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" Foreground="#BDBDBD" VerticalAlignment="Center" Margin="12,0"/>
                            <TextBox Grid.Column="1" FontSize="14" VerticalAlignment="Center" BorderThickness="0" Background="Transparent" Foreground="#212121"
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" Padding="5,8"
                                     materialDesign:HintAssist.Hint="Search products..." materialDesign:HintAssist.Foreground="#BDBDBD"/>
                        </Grid>
                    </Border>

                    <ComboBox Grid.Column="1" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" 
                              Height="40" FontSize="14" VerticalContentAlignment="Center" Padding="12,0"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}" BorderBrush="#E0E0E0" Foreground="#212121" Margin="0,0,15,0"/>

                    <CheckBox Grid.Column="2" IsChecked="{Binding IsLowStockOnly}" Content="Low Stock" FontSize="14" FontWeight="Medium" Foreground="#424242" VerticalAlignment="Center" Margin="0,0,15,0" Style="{StaticResource MaterialDesignCheckBox}"/>
                    
                    <Button Grid.Column="3" Width="40" Height="40" Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="#E0E0E0" BorderThickness="1" Padding="0" Background="White"
                            Command="{Binding PrintInventoryCommand}">
                        <materialDesign:PackIcon Kind="PrinterPos" Width="20" Height="20" Foreground="#424242"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Items List -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Products}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="300" Height="280" Background="White" CornerRadius="12" Margin="0,0,20,20" BorderBrush="#E0E0E0" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="120"/> <!-- Image Area -->
                                        <RowDefinition Height="*"/>   <!-- Info Area -->
                                        <RowDefinition Height="Auto"/> <!-- Actions Area -->
                                    </Grid.RowDefinitions>

                                    <!-- Image / Placeholder -->
                                    <Border Grid.Row="0" Background="#F8FAFB" CornerRadius="12,12,0,0">
                                        <Grid>
                                            <materialDesign:PackIcon Kind="ImageOutline" Width="30" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#E0E0E0"/>
                                            <Image Source="{Binding ImagePath}" Stretch="UniformToFill"/>
                                            
                                            <!-- Status Label (Top Right) -->
                                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" Padding="8,3" CornerRadius="10">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E8F5E9"/> <!-- OK Green -->
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="LowStock">
                                                                <Setter Property="Background" Value="#FFF3E0"/> <!-- LOW Orange -->
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="OutOfStock">
                                                                <Setter Property="Background" Value="#FFEBEE"/> <!-- OUT Red -->
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="9" FontWeight="Black">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="OK"/>
                                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="LowStock">
                                                                    <Setter Property="Text" Value="LOW"/>
                                                                    <Setter Property="Foreground" Value="#EF6C00"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="OutOfStock">
                                                                    <Setter Property="Text" Value="OUT"/>
                                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Product Info -->
                                    <Border Grid.Row="1" Padding="15">
                                        <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" Foreground="#212121"/>
                                        <TextBlock Text="{Binding Category}" FontSize="11" FontWeight="Medium" Foreground="#9E9E9E" Margin="0,2,0,0"/>

                                        <Grid Margin="0,15,0,0">
                                            <StackPanel>
                                                <TextBlock Text="STOCK" FontSize="9" FontWeight="Black" Foreground="#BDBDBD"/>
                                                <TextBlock Text="{Binding StockQuantity}" FontSize="14" FontWeight="Bold" Foreground="#212121"/>
                                            </StackPanel>
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="PRICE" FontSize="9" FontWeight="Black" Foreground="#BDBDBD" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding Price, StringFormat='${0:N2}'}" FontSize="14" FontWeight="Bold" Foreground="#1B60F5" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                    <!-- Bottom Actions -->
                                    <Grid Grid.Row="2" Margin="15,0,15,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Receive Stock Button -->
                                        <Button Grid.Column="0" Command="{Binding DataContext.AdjustStockCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Background="#EFFFF3" BorderThickness="0" Height="40" Margin="0,0,5,0" Padding="0" materialDesign:ButtonAssist.CornerRadius="6">
                                            <Button.CommandParameter>
                                                <MultiBinding Converter="{StaticResource MultiValueConverter}">
                                                    <Binding Path="."/>
                                                    <Binding Source="1"/>
                                                </MultiBinding>
                                            </Button.CommandParameter>
                                            <materialDesign:PackIcon Kind="PackageVariantPlus" Width="18" Height="18" Foreground="#2E7D32"/>
                                        </Button>

                                        <!-- Edit Product Button -->
                                        <Button Grid.Column="1" Command="{Binding DataContext.OpenEditProductCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"
                                                Background="#E3F2FD" BorderThickness="0" Height="40" Margin="0,0,5,0" Padding="0" materialDesign:ButtonAssist.CornerRadius="6">
                                            <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18" Foreground="#1565C0"/>
                                        </Button>

                                        <!-- Delete Product Button -->
                                        <Button Grid.Column="2" Command="{Binding DataContext.DeleteProductCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"
                                                Background="#FFEBEE" BorderThickness="0" Height="40" Padding="0" materialDesign:ButtonAssist.CornerRadius="6">
                                            <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" Foreground="#C62828"/>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Add/Edit Product Overlay -->
        <Border Background="{StaticResource GlassOverlayBrush}" Visibility="{Binding IsAddProductOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="White" Width="600" MaxHeight="850" CornerRadius="16" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="40" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title & Close -->
                    <Grid Grid.Row="0" Margin="0,0,0,30">
                        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#212121" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="New Product"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Text" Value="Edit Product"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Command="{Binding CloseAddProductCommand}" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="0" Width="30" Height="30" Style="{StaticResource MaterialDesignFlatButton}">
                            <materialDesign:PackIcon Kind="Close" Width="20" Height="20" Foreground="#757575"/>
                        </Button>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Image Upload Area (Fixed Square) -->
                            <Button Command="{Binding UploadImageCommand}" Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" Width="150" Height="150" Margin="0,0,0,30" Padding="0" Style="{StaticResource MaterialDesignFlatButton}">
                                <Grid Width="150" Height="150">
                                    <Rectangle Stroke="#E0E0E0" StrokeThickness="1.5" StrokeDashArray="4 2" RadiusX="12" RadiusY="12"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="ImageOutline" Width="30" Height="30" HorizontalAlignment="Center" Foreground="#BDBDBD"/>
                                        <TextBlock Text="Click to Upload" FontSize="11" FontWeight="Bold" Foreground="#9E9E9E" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    </StackPanel>
                                    <!-- Preview -->
                                    <Border CornerRadius="12" ClipToBounds="True">
                                        <Image Source="{Binding CurrentImagePath}" Stretch="UniformToFill">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CurrentImagePath, Converter={StaticResource StringToVisibilityConverter}}" Value="Visible">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                    </Border>
                                </Grid>
                            </Button>

                            <!-- Fields -->
                            <TextBlock Text="PRODUCT NAME" FontSize="10" FontWeight="Black" Foreground="#BDBDBD" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding NewProductName}" Height="42" FontSize="14" VerticalContentAlignment="Center" Padding="15,0" 
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="#212121" BorderBrush="#E0E0E0" Margin="0,0,0,25"/>

                            <Grid Margin="0,0,0,25">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="CATEGORY" FontSize="10" FontWeight="Black" Foreground="#BDBDBD" Margin="0,0,0,8"/>
                                    <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding NewProductCategory}" Height="42" FontSize="14" 
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}" BorderBrush="#E0E0E0" Foreground="#212121"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="STATUS" FontSize="10" FontWeight="Black" Foreground="#BDBDBD" Margin="0,0,0,8"/>
                                    <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding NewProductStatus}" Height="42" FontSize="14" 
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}" BorderBrush="#E0E0E0" Foreground="#212121"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,25">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="PRICE ($)" FontSize="10" FontWeight="Black" Foreground="#BDBDBD" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding NewProductPrice}" Height="42" FontSize="14" VerticalContentAlignment="Center" Padding="15,0" 
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderBrush="#E0E0E0" Foreground="#212121"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="COST ($)" FontSize="10" FontWeight="Black" Foreground="#BDBDBD" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding NewProductCost}" Height="42" FontSize="14" VerticalContentAlignment="Center" Padding="15,0" 
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderBrush="#E0E0E0" Foreground="#212121"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="STOCK" FontSize="10" FontWeight="Black" Foreground="#BDBDBD" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding NewProductStock}" Height="42" FontSize="14" VerticalContentAlignment="Center" Padding="15,0" 
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderBrush="#E0E0E0" Foreground="#212121"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="DESCRIPTION (Optional)" FontSize="10" FontWeight="Black" Foreground="#BDBDBD" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding NewProductDescription}" Height="90" FontSize="14" Padding="15" 
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderBrush="#E0E0E0" Foreground="#212121" TextWrapping="Wrap" AcceptsReturn="True"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer Buttons -->
                    <Grid Grid.Row="2" Margin="0,30,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Command="{Binding CloseAddProductCommand}" Content="Cancel" Height="42" Width="100" FontSize="13" FontWeight="Bold" 
                                    Background="White" Foreground="#757575" BorderBrush="#E0E0E0" BorderThickness="1" materialDesign:ButtonAssist.CornerRadius="8" Margin="0,0,10,0" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                            <Button Command="{Binding SaveProductCommand}" Content="Save Product" Height="42" Width="140" FontSize="13" FontWeight="Bold" 
                                    Background="#1B60F5" Foreground="White" BorderThickness="0" materialDesign:ButtonAssist.CornerRadius="8" Style="{StaticResource MaterialDesignRaisedButton}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
