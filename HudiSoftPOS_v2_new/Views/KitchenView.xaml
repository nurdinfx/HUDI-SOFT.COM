<UserControl x:Class="HudiSoftPOS.Views.KitchenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:HudiSoftPOS.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1366"
             Background="#F4F6F8">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Lanes -->
        </Grid.RowDefinitions>

        <!-- ══════════════════ KITCHEN HEADER ══════════════════ -->
        <Border Grid.Row="0" Background="#1565C0">
            <Grid Height="64" Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Title -->
                    <ColumnDefinition Width="*"/>    <!-- Stats area -->
                    <ColumnDefinition Width="Auto"/> <!-- Buttons -->
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="ChefHat" Width="28" Height="28" Foreground="White" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Kitchen Display System" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="40,0,0,0">
                    <Border Background="#2AFFFFFF" CornerRadius="4" Padding="12,6" Margin="0,0,12,0" BorderBrush="#20FFFFFF" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="PENDING:" Foreground="#BBDEFB" FontSize="11" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding PendingCount}" Foreground="White" FontSize="16" FontWeight="Black" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#50FFA500" CornerRadius="4" Padding="12,6" Margin="0,0,12,0" BorderBrush="#40FFA500" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="COOKING:" Foreground="White" FontSize="11" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CookingCount}" Foreground="White" FontSize="16" FontWeight="Black" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#5043A047" CornerRadius="4" Padding="12,6" BorderBrush="#4043A047" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="READY:" Foreground="White" FontSize="11" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ReadyCount}" Foreground="White" FontSize="16" FontWeight="Black" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding LoadOrdersCommand}"
                            Background="White" Foreground="#1565C0" BorderThickness="0"
                            Height="38" Padding="20,0" FontSize="13" FontWeight="Black"
                            materialDesign:ButtonAssist.CornerRadius="6"
                            Style="{StaticResource MaterialDesignRaisedButton}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="REFRESH" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════ ORDER LANES ══════════════════ -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Column 1: New Orders -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="#1565C0" Padding="15,10" CornerRadius="6,6,0,0">
                    <TextBlock Text="NEW ORDERS" FontSize="14" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,15,0,0">
                    <ItemsControl ItemsSource="{Binding NewOrders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" Margin="0,0,0,15" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.1" Color="Black"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <TextBlock Text="{Binding Id, StringFormat='Order #{0}'}" FontWeight="Black" FontSize="18" Foreground="#212121"/>
                                            <TextBlock Text="{Binding OrderTime, StringFormat='HH:mm'}" Foreground="#757575" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14"/>
                                        </Grid>
                                        <StackPanel Grid.Row="1" Margin="0,15">
                                            <TextBlock Text="Items:" Foreground="#9E9E9E" FontSize="11" FontWeight="Bold"/>
                                            <!-- In a real app, this would be a nested ListBox of OrderItems -->
                                            <TextBlock Text="Various Kitchen Items..." Foreground="#424242" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Row="2" Content="START COOKING" 
                                                Command="{Binding DataContext.MarkAsCookingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" 
                                                Background="#FB8C00" Foreground="White" Height="48" 
                                                FontSize="13" FontWeight="Black" materialDesign:ButtonAssist.CornerRadius="6"
                                                Style="{StaticResource MaterialDesignRaisedButton}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Column 2: Cooking -->
            <Grid Grid.Column="1" Margin="10,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="#FB8C00" Padding="15,10" CornerRadius="6,6,0,0">
                    <TextBlock Text="COOKING" FontSize="14" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,15,0,0">
                    <ItemsControl ItemsSource="{Binding CookingOrders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" Margin="0,0,0,15" Padding="20" BorderBrush="#FB8C00" BorderThickness="1,1,1,4">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.1" Color="Black"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <TextBlock Text="{Binding Id, StringFormat='Order #{0}'}" FontWeight="Black" FontSize="18" Foreground="#212121"/>
                                            <TextBlock Text="{Binding OrderTime, StringFormat='HH:mm'}" Foreground="#757575" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14"/>
                                        </Grid>
                                        <StackPanel Grid.Row="1" Margin="0,15">
                                            <TextBlock Text="Items:" Foreground="#9E9E9E" FontSize="11" FontWeight="Bold"/>
                                            <TextBlock Text="Various Kitchen Items..." Foreground="#424242" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                            <TextBlock Text="Status: Cooking In Progress" Foreground="#FB8C00" FontSize="12" FontWeight="Bold" Margin="0,8,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Row="2" Content="MARK AS READY" 
                                                Command="{Binding DataContext.MarkAsReadyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" 
                                                Background="#43A047" Foreground="White" Height="48" 
                                                FontSize="13" FontWeight="Black" materialDesign:ButtonAssist.CornerRadius="6"
                                                Style="{StaticResource MaterialDesignRaisedButton}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Column 3: Ready -->
            <Grid Grid.Column="2" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="#43A047" Padding="15,10" CornerRadius="6,6,0,0">
                    <TextBlock Text="READY FOR DELIVERY" FontSize="14" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,15,0,0">
                    <ItemsControl ItemsControl.ItemsSource="{Binding ReadyOrders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" Margin="0,0,0,15" Padding="20" BorderBrush="#43A047" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.1" Color="Black"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <TextBlock Text="{Binding Id, StringFormat='Order #{0}'}" FontWeight="Black" FontSize="18" Foreground="#212121"/>
                                            <TextBlock Text="{Binding OrderTime, StringFormat='HH:mm'}" Foreground="#757575" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14"/>
                                        </Grid>
                                        <StackPanel Grid.Row="1" Margin="0,15">
                                            <TextBlock Text="Items:" Foreground="#9E9E9E" FontSize="11" FontWeight="Bold"/>
                                            <TextBlock Text="Various Kitchen Items..." Foreground="#424242" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                            <TextBlock Text="WAITING FOR PICKUP" Foreground="#43A047" FontSize="12" FontWeight="Black" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Row="2" Content="DELIVERED" 
                                                Command="{Binding DataContext.MarkAsCompletedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" 
                                                Background="#1565C0" Foreground="White" Height="48" 
                                                FontSize="13" FontWeight="Black" materialDesign:ButtonAssist.CornerRadius="6"
                                                Style="{StaticResource MaterialDesignRaisedButton}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
