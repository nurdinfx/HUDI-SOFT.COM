<UserControl x:Class="HudiSoftPOS.Views.CustomerLedgerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:HudiSoftPOS.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1366">
    <Grid Background="#F8FAFB"> <!-- Light background to match mockup page style -->
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Blue Header -->
                <RowDefinition Height="Auto"/> <!-- Select Customer Bar -->
                <RowDefinition Height="Auto"/> <!-- Stats Cards -->
                <RowDefinition Height="Auto"/> <!-- Add Transaction Bar -->
                <RowDefinition Height="*"/>    <!-- DataGrid -->
            </Grid.RowDefinitions>

            <!-- 1. Blue Header Section -->
            <Border Grid.Row="0" Background="#1B60F5" CornerRadius="12" Padding="25" Margin="0,0,0,20">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Customer Ledger" FontSize="28" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Manage customer accounts and transactions" FontSize="14" FontWeight="Medium" Foreground="#E3F2FD" Margin="0,5,0,0"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentDateTime}" FontSize="11" Foreground="#E3F2FD" HorizontalAlignment="Right"/>
                        <TextBlock Text="System Admin" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                        <TextBlock Text="Logout" FontSize="11" FontWeight="Bold" Foreground="#FF8A80" HorizontalAlignment="Right" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 2. Select Customer & Actions Bar -->
            <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,20" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Select Customer" FontSize="14" FontWeight="SemiBold" Foreground="#757575" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <ComboBox ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" DisplayMemberPath="Name" 
                                  Width="300" Height="40" FontSize="14" VerticalContentAlignment="Center" 
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}" BorderBrush="#E0E0E0" Foreground="#212121"/>
                        <Button Command="{Binding OpenAddCustomerCommand}" Content="+ Add New" Margin="15,0,0,0" 
                                Background="#1B60F5" Foreground="White" BorderThickness="0" Height="40" Padding="15,0" materialDesign:ButtonAssist.CornerRadius="8"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding RefreshCommand}" Style="{StaticResource MaterialDesignFlatButton}" Background="#ECEFF1" Width="50" Height="40" materialDesign:ButtonAssist.CornerRadius="8" Margin="0,0,10,0">
                            <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" Foreground="#455A64"/>
                        </Button>
                        <Button Command="{Binding PrintInvoiceCommand}" Content="Print Invoice" 
                                Background="#2E7D32" Foreground="White" BorderThickness="0" Height="40" Padding="20,0" materialDesign:ButtonAssist.CornerRadius="8">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Printer" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Print Invoice" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 3. Stats Cards Section -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Debit -->
                <Border Grid.Column="0" Background="#1B60F5" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Total Debit" FontSize="12" FontWeight="Medium" Foreground="#E3F2FD"/>
                        <TextBlock Text="{Binding TotalDebit, StringFormat='${0:N2}'}" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Credit -->
                <Border Grid.Column="2" Background="#2E7D32" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Total Credit" FontSize="12" FontWeight="Medium" Foreground="#E8F5E9"/>
                        <TextBlock Text="{Binding TotalCredit, StringFormat='${0:N2}'}" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Current Balance -->
                <Border Grid.Column="4" Background="#D81B60" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Current Balance" FontSize="12" FontWeight="Medium" Foreground="#FCE4EC"/>
                        <TextBlock Text="{Binding CurrentBalance, StringFormat='${0:N2}'}" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Account Status -->
                <Border Grid.Column="6" Background="#EF5350" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Account Status" FontSize="12" FontWeight="Medium" Foreground="#FFEBEE"/>
                        <TextBlock Text="{Binding AccountStatus}" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 4. Add New Transaction Bar -->
            <Border Grid.Row="3" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Add New Transaction" FontSize="16" FontWeight="SemiBold" Foreground="#212121" Margin="0,0,0,15"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Type" FontSize="10" FontWeight="Black" Foreground="#9E9E9E" Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding TransactionTypes}" SelectedItem="{Binding NewTransactionType}" 
                                      Height="40" FontSize="13" VerticalContentAlignment="Center" 
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}" BorderBrush="#E0E0E0" Foreground="#212121"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Amount ($)" FontSize="10" FontWeight="Black" Foreground="#9E9E9E" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding NewTransactionAmount}" Height="40" FontSize="14" VerticalContentAlignment="Center" Padding="12,0" Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="#212121" BorderBrush="#E0E0E0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Reference" FontSize="10" FontWeight="Black" Foreground="#9E9E9E" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding NewTransactionReference}" Height="40" FontSize="14" VerticalContentAlignment="Center" Padding="12,0" Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="#212121" BorderBrush="#E0E0E0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="6">
                            <TextBlock Text="Description *" FontSize="10" FontWeight="Black" Foreground="#9E9E9E" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding NewTransactionDescription}" Height="40" FontSize="14" VerticalContentAlignment="Center" Padding="12,0" Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="#212121" BorderBrush="#E0E0E0"/>
                        </StackPanel>

                        <Button Grid.Column="8" Command="{Binding AddTransactionCommand}" Content="Add Transaction" VerticalAlignment="Bottom"
                                Background="#2E7D32" Foreground="White" BorderThickness="0" Height="40" Padding="20,0" materialDesign:ButtonAssist.CornerRadius="8"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 5. Ledger Table -->
            <Border Grid.Row="4" Background="White" CornerRadius="12" BorderBrush="#E0E0E0" BorderThickness="1" ClipToBounds="True">
                <DataGrid ItemsSource="{Binding Transactions}" AutoGenerateColumns="False" IsReadOnly="True" 
                          Background="Transparent" BorderThickness="0" CanUserAddRows="False" 
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F5F5F5"
                          RowHeight="60" FontSize="13" Foreground="#212121" RowBackground="White">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFB"/>
                            <Setter Property="Foreground" Value="#757575"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="15,10"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="DATE &amp; TIME" Binding="{Binding TransactionDate, StringFormat='dd/MM/yyyy HH:mm'}" Width="180">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="15,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTextColumn Header="REFERENCE" Binding="{Binding Reference}" Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTemplateColumn Header="DEBIT" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="13" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,15,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value=""/>
                                                <Setter Property="Foreground" Value="#C62828"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="Debit">
                                                        <Setter Property="Text" Value="{Binding Amount, StringFormat='${0:N2}'}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="CREDIT" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="13" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,15,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value=""/>
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="Credit">
                                                        <Setter Property="Text" Value="{Binding Amount, StringFormat='${0:N2}'}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="BALANCE" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,15,0">
                                        <TextBlock Text="{Binding BalanceAfter, StringFormat='${0:N2}'}" FontSize="13" FontWeight="Bold" Foreground="#212121"/>
                                        <TextBlock Text=" Rec" FontSize="10" Foreground="#C62828" VerticalAlignment="Bottom" Margin="4,0,0,2"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="REMARKS" Binding="{Binding Description}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- Add New Customer Overlay -->
        <Border Background="{StaticResource GlassOverlayBrush}" Visibility="{Binding IsAddCustomerOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="White" Width="500" CornerRadius="16" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="35" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Add New Customer" FontSize="20" FontWeight="SemiBold" Foreground="#212121" Margin="0,0,0,25"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Name *" FontSize="10" FontWeight="Black" Foreground="#9E9E9E" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding NewCustomerName}" Height="40" FontSize="14" VerticalContentAlignment="Center" Padding="12,0" Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="#212121" BorderBrush="#E0E0E0" Margin="0,0,0,20"/>

                            <TextBlock Text="Phone" FontSize="10" FontWeight="Black" Foreground="#9E9E9E" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding NewCustomerPhone}" Height="40" FontSize="14" VerticalContentAlignment="Center" Padding="12,0" Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="#212121" BorderBrush="#E0E0E0" Margin="0,0,0,20"/>

                            <TextBlock Text="Email" FontSize="10" FontWeight="Black" Foreground="#9E9E9E" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding NewCustomerEmail}" Height="40" FontSize="14" VerticalContentAlignment="Center" Padding="12,0" Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="#212121" BorderBrush="#E0E0E0" Margin="0,0,0,20"/>

                            <TextBlock Text="Address" FontSize="10" FontWeight="Black" Foreground="#9E9E9E" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding NewCustomerAddress}" Height="100" FontSize="14" Padding="12" Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="#212121" BorderBrush="#E0E0E0" TextWrapping="Wrap" AcceptsReturn="True"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="2" Margin="0,25,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Command="{Binding CloseAddCustomerCommand}" Content="Cancel" Height="40" Width="100" FontSize="13" FontWeight="Bold" 
                                    Background="White" Foreground="#757575" BorderBrush="#E0E0E0" BorderThickness="1" materialDesign:ButtonAssist.CornerRadius="8" Margin="0,0,10,0" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                            <Button Command="{Binding SaveCustomerCommand}" Content="Add Customer" Height="40" Width="140" FontSize="13" FontWeight="Bold" 
                                    Background="#1B60F5" Foreground="White" BorderThickness="0" materialDesign:ButtonAssist.CornerRadius="8" Style="{StaticResource MaterialDesignRaisedButton}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
