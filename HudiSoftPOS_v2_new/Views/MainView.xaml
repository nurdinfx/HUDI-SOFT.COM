<Window x:Class="HudiSoftPOS.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:HudiSoftPOS.ViewModels"
        xmlns:converters="clr-namespace:HudiSoftPOS.Converters"
        mc:Ignorable="d"
        Title="HUDI-SOFT Business Suite"
        Icon="pack://application:,,,/Assets/logo.png"
        Height="720" Width="1280"
        MinWidth="1024" MinHeight="600"
        WindowState="Maximized" WindowStyle="None" ResizeMode="CanResizeWithGrip"
        Background="#F4F6F8"
        TextElement.FontFamily="{DynamicResource MaterialDesignFont}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="90" 
                      CornerRadius="0" 
                      GlassFrameThickness="0" 
                      NonClientFrameEdges="None" 
                      ResizeBorderThickness="8" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:HideOnSmallWidthConverter x:Key="HideOnSmallWidthConverter"/>

        <!-- Sidebar Nav Button Style: large touch-friendly items that fit sidebar -->
        <Style x:Key="SidebarNavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="68"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8" Margin="8,2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#2AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Body -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════ HEADER ═══════════════════ -->
        <Border Grid.Row="0" Background="#1565C0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid Height="90" Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Hamburger -->
                    <ColumnDefinition Width="Auto"/> <!-- Logo Area -->
                    <ColumnDefinition Width="*"/>    <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/> <!-- Right info -->
                    <ColumnDefinition Width="Auto"/> <!-- Logout -->
                    <ColumnDefinition Width="Auto"/> <!-- Window controls: Min, Max, Close -->
                </Grid.ColumnDefinitions>

                <!-- Hamburger Menu -->
                <Button Grid.Column="0" Command="{Binding ToggleSidebarCommand}"
                        Style="{StaticResource MaterialDesignIconForegroundButton}"
                        Foreground="White" Width="50" Height="50" Margin="5,0,10,0">
                    <materialDesign:PackIcon Kind="Menu" Width="28" Height="28"/>
                </Button>

                <!-- Logo + Dismissible subtitle -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,30,0" Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="10" Background="White" Margin="0,0,12,0" VerticalAlignment="Center">
                        <Image Source="pack://application:,,,/Assets/logo.jpg" Stretch="Uniform" Margin="5"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="HUDI-SOFT POS" Foreground="#BBDEFB" FontSize="11" FontWeight="Bold" Margin="0,0,0,-2"/>
                        <TextBlock Text="HUDI-SOFT Business Suite" Foreground="White" FontSize="22" FontWeight="Black"/>
                        <!-- Dismissible component: click X to hide -->
                        <Border Background="#0D47A1" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" Margin="0,4,0,0"
                                Visibility="{Binding IsHeaderSubtitleVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Xess Suite" Foreground="#BBDEFB" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Button Command="{Binding DismissHeaderSubtitleCommand}" Width="24" Height="24" Margin="6,0,0,0"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Dismiss">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                                <TextBlock Text="✕" FontSize="12" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1565C0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>
                        <Border Background="#4CAF50" CornerRadius="4" Padding="6,1" HorizontalAlignment="Left" Margin="0,2,0,0">
                            <TextBlock Text="ONLINE" Foreground="White" FontSize="9" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Current Page Title (center area) -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20,0,0,0">
                    <TextBlock Text="{Binding CurrentPageTitle}" Foreground="White" FontSize="16" FontWeight="Bold"/>
                </StackPanel>

                <!-- Right: Admin Info + Time -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0" Visibility="{Binding Path=ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource HideOnSmallWidthConverter}, ConverterParameter=1000}">
                        <TextBlock Text="{Binding CurrentUserRole}" Foreground="#BBDEFB" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding CurrentUserFullName}" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,15,0">
                        <TextBlock Text="{Binding CurrentDate}" Foreground="#BBDEFB" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Text="{Binding CurrentTime}" Foreground="White" FontSize="20" FontWeight="Black"/>
                    </StackPanel>
                </StackPanel>

                <!-- Logout Button -->
                <Button Grid.Column="4" Command="{Binding LogoutCommand}"
                        Background="White" Foreground="#1565C0" BorderThickness="0"
                        Height="44" Padding="25,0" FontSize="14" FontWeight="Black"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Logout" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="LOGOUT" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Window controls: Minimize, Maximize, Close -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="BtnMinimize" Click="BtnMinimize_Click" Width="46" Height="32" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Minimize">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="0">
                                    <materialDesign:PackIcon Kind="WindowMinimize" Width="18" Height="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#20FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="BtnMaximize" Click="BtnMaximize_Click" Width="46" Height="32" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Maximize">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="0">
                                    <materialDesign:PackIcon x:Name="MaxIcon" Kind="WindowMaximize" Width="16" Height="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#20FFFFFF"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                                        <Setter TargetName="MaxIcon" Property="Kind" Value="WindowRestore"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="BtnClose" Click="BtnClose_Click" Width="46" Height="32" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Close">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="0">
                                    <materialDesign:PackIcon Kind="WindowClose" Width="18" Height="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E81123"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════ BODY ═══════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/> <!-- Sidebar (collapsible) -->
                <ColumnDefinition Width="*"/>    <!-- Content -->
            </Grid.ColumnDefinitions>

            <!-- Main Content Area (Background Layer) -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Panel.ZIndex="0"/>

            <!-- Overlay: click blank area (right side) to close sidebar - covers content when sidebar open -->
            <Button Grid.Column="1" Panel.ZIndex="10"
                    Command="{Binding CloseSidebarCommand}"
                    Visibility="{Binding IsSidebarOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Background="Transparent" BorderThickness="0" Cursor="Arrow"
                    materialDesign:RippleAssist.IsDisabled="True"
                    ToolTip="Click to close menu">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Sidebar (Top Layer) - larger width -->
            <Border Grid.Column="0" Background="#1565C0" Width="320"
                    Visibility="{Binding IsSidebarOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Branding Header -->
                        <RowDefinition Height="*"/>    <!-- Nav Items -->
                    </Grid.RowDefinitions>

                    <!-- Branding Section Top of Sidebar -->
                    <Grid Grid.Row="0" Margin="15,20,15,30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Logo -->
                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" Background="White" Margin="0,0,12,0">
                            <Image Source="pack://application:,,,/Assets/logo.jpg" Stretch="Uniform" Margin="5"/>
                        </Border>
                        
                        <!-- Text -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="HUDI-SOFT" Foreground="White" FontSize="16" FontWeight="Black" Margin="0,0,0,-2"/>
                            <TextBlock Text="POS &amp; Business Suite" Foreground="#BBDEFB" FontSize="9" FontWeight="Bold"/>
                        </StackPanel>
                        
                        <!-- Close Button: click to close sidebar -->
                        <Button Grid.Column="2" Command="{Binding CloseSidebarCommand}"
                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                Foreground="White" Width="32" Height="32" Padding="0" ToolTip="Close menu">
                            <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                        </Button>
                    </Grid>

                    <!-- Scroll down: visible scrollbar when content overflows -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly" Margin="0,0,2,0">
                        <StackPanel Margin="0,0,0,10">
                        <StackPanel.Resources>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                <Setter Property="FontSize" Value="16"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </StackPanel.Resources>

                        <Button Command="{Binding NavigateToDashboardCommand}" Visibility="{Binding ShowDashboard, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="Dashboard">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FDD835" Margin="0,0,14,0">
                                    <materialDesign:PackIcon Kind="ViewDashboard" Width="24" Height="24" Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToPOSCommand}" Visibility="{Binding ShowPOS, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="Point of Sale">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FDD835" Margin="0,0,14,0">
                                    <materialDesign:PackIcon Kind="Monitor" Width="24" Height="24" Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="POS" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToKitchenCommand}" Visibility="{Binding ShowKitchen, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="Kitchen">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FDD835" Margin="0,0,14,0">
                                    <materialDesign:PackIcon Kind="ChefHat" Width="24" Height="24" Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Kitchen" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToOrdersCommand}" Visibility="{Binding ShowOrders, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="Orders">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FDD835" Margin="0,0,14,0">
                                    <materialDesign:PackIcon Kind="Receipt" Width="24" Height="24" Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Orders" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToTablesCommand}" Visibility="{Binding ShowTables, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="Tables">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FDD835" Margin="0,0,14,0">
                                    <materialDesign:PackIcon Kind="TableFurniture" Width="24" Height="24" Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Tables" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToInventoryCommand}" Visibility="{Binding ShowInventory, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="Inventory">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FDD835" Margin="0,0,14,0">
                                    <materialDesign:PackIcon Kind="PackageVariant" Width="24" Height="24" Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Inventory" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToCustomerLedgerCommand}" Visibility="{Binding ShowLedger, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="Customer Ledger">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FDD835" Margin="0,0,14,0">
                                    <materialDesign:PackIcon Kind="AccountCircle" Width="24" Height="24" Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Customer Ledger" TextWrapping="Wrap" MaxWidth="160" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToFinanceCommand}" Visibility="{Binding ShowFinance, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="Finance">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FDD835" Margin="0,0,14,0">
                                    <materialDesign:PackIcon Kind="Finance" Width="24" Height="24" Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Finance" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToPurchaseCommand}" Visibility="{Binding ShowPurchase, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="Purchase">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FDD835" Margin="0,0,14,0">
                                    <materialDesign:PackIcon Kind="BasketOutline" Width="24" Height="24" Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Purchase" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToUsersCommand}" Visibility="{Binding ShowUsers, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="Users">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FDD835" Margin="0,0,14,0">
                                    <materialDesign:PackIcon Kind="AccountGroup" Width="24" Height="24" Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Users" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToReportsCommand}" Visibility="{Binding ShowReports, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="Reports">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FDD835" Margin="0,0,14,0">
                                    <materialDesign:PackIcon Kind="ChartBar" Width="24" Height="24" Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Reports" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToSettingsCommand}" Visibility="{Binding ShowSettings, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="Settings">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FDD835" Margin="0,0,14,0">
                                    <materialDesign:PackIcon Kind="SettingsOutline" Width="24" Height="24" Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Settings" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToConnectPhoneCommand}" Visibility="{Binding ShowConnectPhone, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="Connect Phone">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FDD835" Margin="0,0,14,0">
                                    <materialDesign:PackIcon Kind="CellPhone" Width="24" Height="24" Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Connect Phone" TextWrapping="Wrap" MaxWidth="160" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToLicenseCommand}" Visibility="{Binding ShowSettings, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="License">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FDD835" Margin="0,0,14,0">
                                    <materialDesign:PackIcon Kind="KeyOutline" Width="24" Height="24" Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="License Mgmt" TextWrapping="Wrap" MaxWidth="160" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Separator -->
                        <Rectangle Height="1" Fill="#3AFFFFFF" Margin="15,10"/>

                        <Button Command="{Binding LogoutCommand}" ToolTip="Logout">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#EF5350" Margin="0,0,14,0">
                                    <materialDesign:PackIcon Kind="Logout" Width="24" Height="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Logout" Foreground="#EF9A9A" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
