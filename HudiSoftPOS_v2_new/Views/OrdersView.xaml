<UserControl x:Class="HudiSoftPOS.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:HudiSoftPOS.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1440" 
             Background="#F4F6F8">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Filters -->
            <RowDefinition Height="*"/>    <!-- Orders List -->
        </Grid.RowDefinitions>

        <!-- ══════════════════ ORDERS HEADER (Precisely like image) ══════════════════ -->
        <Border Grid.Row="0" Background="#1565C0">
            <Grid Height="68" Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Orders button/Printer -->
                    <ColumnDefinition Width="*"/>    <!-- Stats area -->
                    <ColumnDefinition Width="Auto"/> <!-- Action buttons -->
                </Grid.ColumnDefinitions>

                <!-- Left Section: Orders + Printer Buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Orders" Background="White" Foreground="#1565C0" FontWeight="Bold" Height="38" Padding="15,0" Margin="0,0,10,0" materialDesign:ButtonAssist.CornerRadius="6"/>
                    <Button Content="Other Printer" Background="White" Foreground="#1565C0" FontWeight="Bold" Height="38" Padding="15,0" Margin="0,0,10,0" materialDesign:ButtonAssist.CornerRadius="6"/>
                    <Border Background="White" Width="38" Height="38" CornerRadius="6">
                        <TextBlock Text="1" Foreground="#1565C0" FontWeight="Black" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="16"/>
                    </Border>
                </StackPanel>

                <!-- Center Section: Stats (Precisely aligned) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="30,0,0,0">
                    <Border Background="#1A237E" CornerRadius="6" Padding="12,4" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Margin="0,0,15,0">
                                <TextBlock Text="TOTAL" Foreground="#BBDEFB" FontSize="9" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TotalSales, StringFormat='${0:N2}'}" Foreground="White" FontSize="15" FontWeight="Black"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,0">
                                <TextBlock Text="VAT" Foreground="#BBDEFB" FontSize="9" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TotalVat, StringFormat='${0:N2}'}" Foreground="White" FontSize="15" FontWeight="Black"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="PENDING" Foreground="#BBDEFB" FontSize="9" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TotalPending, StringFormat='${0:N2}'}" Foreground="#FFEB3B" FontSize="15" FontWeight="Black"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right Section: Header Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding TablePaymentInvCommand}" Content="Table Payment (Inv)" Background="#1A237E" Foreground="White" BorderThickness="0" Height="40" Padding="15,0" Margin="0,0,8,0" materialDesign:ButtonAssist.CornerRadius="6" FontSize="12"/>
                    <Button Command="{Binding TablePaymentCommand}" Content="Table Payment" Background="#1A237E" Foreground="White" BorderThickness="0" Height="40" Padding="15,0" Margin="0,0,8,0" materialDesign:ButtonAssist.CornerRadius="6" FontSize="12"/>
                    <Button Command="{Binding PrintAllCommand}" Content="Print All" Background="#1A237E" Foreground="White" BorderThickness="0" Height="40" Padding="15,0" Margin="0,0,8,0" materialDesign:ButtonAssist.CornerRadius="6" FontSize="12"/>
                    <Button Command="{Binding DataContext.NavigateToPOSCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Content="+ Add" Background="#4CAF50" Foreground="White" BorderThickness="0" Height="40" Padding="20,0" Margin="0,0,8,0" materialDesign:ButtonAssist.CornerRadius="6" FontSize="13" FontWeight="Bold"/>
                    <Button Content="More" Background="#1A237E" Foreground="White" BorderThickness="0" Height="40" Padding="15,0" materialDesign:ButtonAssist.CornerRadius="6" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════ FILTER BAR AREA ══════════════════ -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="10,12">
            <WrapPanel Orientation="Horizontal">
                <!-- Date Filters -->
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="From" FontSize="10" FontWeight="Bold" Foreground="#757575" Margin="2,0,0,2"/>
                    <DatePicker SelectedDate="{Binding FromDate}" Width="100" Height="36" Padding="6,0" Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="To" FontSize="10" FontWeight="Bold" Foreground="#757575" Margin="2,0,0,2"/>
                    <DatePicker SelectedDate="{Binding ToDate}" Width="100" Height="36" Padding="6,0" Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                </StackPanel>

                <!-- Dropdowns -->
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="Served by" FontSize="10" FontWeight="Bold" Foreground="#757575" Margin="2,0,0,2"/>
                    <ComboBox ItemsSource="{Binding ServedByList}" SelectedItem="{Binding SelectedServedBy}" Width="110" Height="36" Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="Customer" FontSize="10" FontWeight="Bold" Foreground="#757575" Margin="2,0,0,2"/>
                    <ComboBox ItemsSource="{Binding CustomersList}" SelectedItem="{Binding SelectedCustomer}" Width="130" Height="36" Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="Rooms" FontSize="10" FontWeight="Bold" Foreground="#757575" Margin="2,0,0,2"/>
                    <ComboBox ItemsSource="{Binding RoomsList}" SelectedItem="{Binding SelectedRoom}" Width="90" Height="36" Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="Tables" FontSize="10" FontWeight="Bold" Foreground="#757575" Margin="2,0,0,2"/>
                    <ComboBox ItemsSource="{Binding TablesList}" SelectedItem="{Binding SelectedTable}" Width="90" Height="36" Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="Status" FontSize="10" FontWeight="Bold" Foreground="#757575" Margin="2,0,0,2"/>
                    <ComboBox ItemsSource="{Binding StatusList}" SelectedItem="{Binding SelectedStatusFilter}" Width="90" Height="36" Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                </StackPanel>

                <!-- Search -->
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="Order Number" FontSize="10" FontWeight="Bold" Foreground="#757575" Margin="2,0,0,2"/>
                    <Border BorderBrush="#757575" BorderThickness="1" CornerRadius="4" Width="180" Height="36" Padding="5,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Kind="Magnify" Width="16" Height="16" Foreground="#757575" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding OrderNumberQuery, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" materialDesign:TextFieldAssist.DecorationVisibility="Hidden"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Reset -->
                <Button Command="{Binding ResetFiltersCommand}" Content="Reset" Background="White" BorderBrush="#212121" BorderThickness="1.5" Foreground="#212121" FontWeight="Bold" Height="38" Padding="15,0" VerticalAlignment="Bottom" Margin="0,0,0,8" materialDesign:ButtonAssist.CornerRadius="6"/>
            </WrapPanel>
        </Border>

        <!-- ══════════════════ ORDERS LIST (DataGrid) ══════════════════ -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Orders}" AutoGenerateColumns="False" 
                  Background="White" BorderThickness="0" CanUserAddRows="False" 
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0"
                  FontSize="11" Foreground="#212121"
                  HeadersVisibility="Column" SelectionUnit="FullRow">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="FontWeight" Value="Black"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                </Style>
            </DataGrid.Resources>
            
            <DataGrid.Columns>
                <!-- Order Info -->
                <DataGridTemplateColumn Header="Order Info" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Margin="10,8">
                                <TextBlock Text="{Binding Id, StringFormat='{}{0:0000}'}" FontWeight="Black" FontSize="11" Foreground="Black"/>
                                <TextBlock Text="{Binding OrderTime, StringFormat='dd/MM/yyyy'}" Foreground="#757575" FontSize="9"/>
                                <TextBlock Text="{Binding OrderTime, StringFormat='hh:mm tt'}" Foreground="#757575" FontSize="9"/>
                                <TextBlock Text="{Binding Status}" Foreground="{Binding Status, Converter={StaticResource StatusToBrushConverter}}" FontSize="9" FontWeight="Bold"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Served by (dynamic: from order's User - users page data) -->
                <DataGridTemplateColumn Header="Served by" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ServedByDisplayName}" VerticalAlignment="Center" Margin="5,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Table (dynamic from POS selection) -->
                <DataGridTemplateColumn Header="Table" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TableName, TargetNullValue=-, FallbackValue=-}" VerticalAlignment="Center" Margin="5,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Customer (dynamic from POS selection) -->
                <DataGridTemplateColumn Header="Customer" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding CustomerName, TargetNullValue=Walking Customer, FallbackValue=Walking Customer}" VerticalAlignment="Center" Margin="5,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Room (dynamic from POS selection) -->
                <DataGridTemplateColumn Header="Room" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Room, TargetNullValue=Main Hall, FallbackValue=Main Hall}" VerticalAlignment="Center" Margin="5,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Payment Badge -->
                <DataGridTemplateColumn Header="Payment" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Background="#FFF9C4" Padding="8,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="cash" FontSize="10" Foreground="#FBC02D" FontWeight="Bold"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Paid -->
                <DataGridTemplateColumn Header="Paid" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="0.00" Foreground="#26A69A" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Amount -->
                <DataGridTemplateColumn Header="Amount" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0">
                                <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N2}'}" FontWeight="Black" FontSize="12" Foreground="Black"/>
                                <TextBlock Text="{Binding Vat, StringFormat='{}VAT: {0:N2}'}" Foreground="#757575" FontSize="9"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Remarks -->
                <DataGridTemplateColumn Header="Remarks" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Actions (Colorful Buttons) -->
                <DataGridTemplateColumn Header="Actions" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5">
                                <Button Command="{Binding DataContext.PrintOrderCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"
                                        Content="Print" Background="#1565C0" Foreground="White" BorderThickness="0" Height="40" Padding="15,0" FontSize="11" materialDesign:ButtonAssist.CornerRadius="6" Margin="0,0,4,0"/>
                                <Button Command="{Binding DataContext.ViewOrderCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"
                                        Content="View" Background="White" Foreground="#1565C0" BorderBrush="#1565C0" BorderThickness="1" Height="40" Padding="15,0" FontSize="11" materialDesign:ButtonAssist.CornerRadius="6" Margin="0,0,4,0"/>
                                <Button Command="{Binding DataContext.UpdateOrderCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"
                                        IsEnabled="{Binding DataContext.CanEditOrPayOrders, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        Content="Update" Background="#FB8C00" Foreground="White" BorderThickness="0" Height="40" Padding="15,0" FontSize="11" materialDesign:ButtonAssist.CornerRadius="6" Margin="0,0,4,0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.CanEditOrPayOrders, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="False">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="Foreground" Value="#BDBDBD"/>
                                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Command="{Binding DataContext.ShowPaymentConfirmCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"
                                        IsEnabled="{Binding DataContext.CanEditOrPayOrders, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        Content="Pay Now" Background="#4CAF50" Foreground="White" BorderThickness="0" Height="40" Padding="15,0" FontSize="11" materialDesign:ButtonAssist.CornerRadius="6" Margin="0,0,4,0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DataContext.CanEditOrPayOrders, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="False">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="Foreground" Value="#BDBDBD"/>
                                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Command="{Binding DataContext.ShowCancelConfirmCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"
                                        Background="#EF5350" Foreground="White" BorderThickness="0" Height="40" Width="40" Padding="0" materialDesign:ButtonAssist.CornerRadius="6">
                                    <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ══════════════════ POPUPS / DIALOGS ══════════════════ -->
        <Grid Grid.RowSpan="3" Background="#66000000" Visibility="{Binding IsOverlayVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            
            <!-- 1. ORDER DETAILS (Receipt View) -->
            <Border Background="White" Width="450" VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="8" Padding="0"
                    Visibility="{Binding IsDetailsPopupOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Close X -->
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Padding="0" Width="30" Height="30" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#757575" Command="{Binding ClosePopupsCommand}">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18"/>
                    </Button>

                    <StackPanel Grid.Row="0" Margin="30,20,30,10">
                        <TextBlock Text="ORDER DETAILS" FontSize="18" FontWeight="Black" HorizontalAlignment="Center" Foreground="Black"/>
                        <TextBlock Text="{Binding SelectedOrder.Id, StringFormat='#{0:0000}'}" FontSize="12" HorizontalAlignment="Center" Foreground="#757575" Margin="0,2"/>
                        <TextBlock Text="{Binding SelectedOrder.OrderTime, StringFormat='ddd, MMM dd, yyyy  hh:mm tt'}" FontSize="10" HorizontalAlignment="Center" Foreground="#757575"/>
                        
                        <Separator Margin="0,15" Background="#E0E0E0"/>
                        
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Customer:" FontSize="10" Foreground="#757575"/>
                                <TextBlock Text="Table:" FontSize="10" Foreground="#757575" Margin="0,5"/>
                                <TextBlock Text="Served By:" FontSize="10" Foreground="#757575"/>
                                <TextBlock Text="Status:" FontSize="10" Foreground="#757575" Margin="0,5"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding SelectedOrder.CustomerName, TargetNullValue=Walking Customer}" FontSize="10" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding SelectedOrder.TableName, TargetNullValue=—}" FontSize="10" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Right" Margin="0,5"/>
                                <TextBlock Text="{Binding SelectedOrder.ServedByDisplayName}" FontSize="10" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding SelectedOrder.Status}" FontSize="10" FontWeight="Bold" Foreground="#EF5350" HorizontalAlignment="Right" Margin="0,5"/>
                            </StackPanel>
                        </Grid>
                        
                        <Separator Margin="0,15" Background="Black" Opacity="1"/>
                        
                        <!-- Items List Header -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Item" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                            <TextBlock Grid.Column="1" Text="Qty" FontSize="10" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="Price" FontSize="10" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="3" Text="Total" FontSize="10" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>

                    <!-- Items Scrollable -->
                    <ScrollViewer Grid.Row="1" MaxHeight="300" Margin="30,0">
                        <ItemsControl ItemsSource="{Binding SelectedOrder.OrderItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Product.Name}" FontSize="10" Foreground="Black" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Quantity}" FontSize="10" Foreground="Black" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Product.Price, StringFormat='{}{0:N2}'}" FontSize="10" Foreground="Black" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="3" Text="{Binding SubTotal, StringFormat='{}{0:N2}'}" FontSize="10" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="30,10,30,20">
                        <Separator Margin="0,10" Background="#E0E0E0"/>
                        
                        <Grid Margin="0,2">
                            <TextBlock Text="Subtotal" FontSize="10" Foreground="#757575"/>
                            <TextBlock Text="{Binding SelectedOrder.TotalAmount, StringFormat='{}{0:N2}'}" FontSize="10" HorizontalAlignment="Right" Foreground="#424242"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <TextBlock Text="Tax / VAT" FontSize="10" Foreground="#757575"/>
                            <TextBlock Text="{Binding SelectedOrder.Vat, StringFormat='{}{0:N2}'}" FontSize="10" HorizontalAlignment="Right" Foreground="#424242"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <TextBlock Text="Discount" FontSize="10" Foreground="#757575"/>
                            <TextBlock Text="- 0.00" FontSize="10" HorizontalAlignment="Right" Foreground="#EF5350"/>
                        </Grid>
                        
                        <Grid Margin="0,15,0,25">
                            <TextBlock Text="TOTAL" FontSize="16" FontWeight="Black" Foreground="Black" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedOrder.TotalAmount, StringFormat='{}{0:N2}'}" FontSize="16" FontWeight="Black" HorizontalAlignment="Right" Foreground="Black"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="Print Receipt" Background="#4285F4" Foreground="White" Height="40" Margin="0,0,5,0" materialDesign:ButtonAssist.CornerRadius="4" Command="{Binding PrintOrderCommand}" CommandParameter="{Binding SelectedOrder}"/>
                            <Button Grid.Column="1" Content="Close" Background="#F5F5F5" Foreground="Black" Height="40" Margin="5,0,0,0" materialDesign:ButtonAssist.CornerRadius="4" BorderBrush="#E0E0E0" BorderThickness="1" Command="{Binding ClosePopupsCommand}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 2. CONFIRM PAYMENT -->
            <Border Background="White" Width="320" VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="8" Padding="20,30"
                    Visibility="{Binding IsPaymentPopupOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="HelpCircle" Width="64" Height="64" Foreground="#1565C0" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock Text="{Binding SelectedOrder.Id, StringFormat='Mark Order {0:0000} as Paid?'}" HorizontalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="Black" Margin="0,0,0,30"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Yes" Background="#F5F5F5" Foreground="Black" Margin="0,0,5,0" Height="40" Command="{Binding ConfirmPaymentCommand}"/>
                        <Button Grid.Column="1" Content="No" Background="#F5F5F5" Foreground="Black" Margin="5,0,0,0" Height="40" Command="{Binding ClosePopupsCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 3. CONFIRM CANCELLATION -->
            <Border Background="White" Width="320" VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="8" Padding="20,30"
                    Visibility="{Binding IsCancelPopupOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="HelpCircle" Width="64" Height="64" Foreground="#1565C0" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock Text="{Binding SelectedOrder.Id, StringFormat='Cancel Order {0:0000}?'}" HorizontalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="Black" Margin="0,0,0,30"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Yes" Background="#F5F5F5" Foreground="Black" Margin="0,0,5,0" Height="40" Command="{Binding ConfirmCancelCommand}"/>
                        <Button Grid.Column="1" Content="No" Background="#F5F5F5" Foreground="Black" Margin="5,0,0,0" Height="40" Command="{Binding ClosePopupsCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
            <!-- 4. CONFIRM PRINT ALL -->
            <Border Background="White" Width="360" VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="8" Padding="20,30"
                    Visibility="{Binding IsPrintAllPopupOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="HelpCircle" Width="64" Height="64" Foreground="#1565C0" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock Text="{Binding Orders.Count, StringFormat='Print receipts for all {0} visible orders?'}" HorizontalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="Black" Margin="0,0,0,30"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Yes" Background="#F5F5F5" Foreground="Black" Margin="0,0,5,0" Height="40" Command="{Binding ConfirmPrintAllCommand}"/>
                        <Button Grid.Column="1" Content="No" Background="#F5F5F5" Foreground="Black" Margin="5,0,0,0" Height="40" Command="{Binding ClosePopupsCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

