<UserControl x:Class="HudiSoftPOS.Views.TableManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1366" 
             Background="#F4F6F8">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title area -->
            <RowDefinition Height="Auto"/> <!-- Stats Bar -->
            <RowDefinition Height="Auto"/> <!-- Filter Bar -->
            <RowDefinition Height="*"/>    <!-- Tables WrapPanel -->
        </Grid.RowDefinitions>

        <!-- ══════════════════ TITLE AREA ══════════════════ -->
        <Grid Grid.Row="0" Margin="20,20,20,10">
            <StackPanel>
                <TextBlock Text="Table Management" FontSize="24" FontWeight="Black" Foreground="#212121"/>
                <TextBlock Text="Manage restaurant floor plan and table availability" FontSize="13" Foreground="#757575" Margin="0,4,0,0"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Command="{Binding RefreshCommand}" 
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        BorderBrush="#E0E0E0" Foreground="#212121"
                        Content="Refresh" Height="40" Padding="15,0" Margin="0,0,10,0"/>
                
                <Button Command="{Binding OpenAddDialogCommand}"                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        Height="40" Padding="20,0" FontSize="13" FontWeight="Bold"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Style="{StaticResource MaterialDesignRaisedButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Add Table" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ══════════════════ STATS BAR ══════════════════ -->
        <Grid Grid.Row="1" Margin="20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#E3F2FD" BorderThickness="1.5" CornerRadius="12" Padding="15" Margin="0,0,15,0">
                <StackPanel>
                    <TextBlock Text="{Binding TotalTables}" FontSize="24" FontWeight="Black" Foreground="#1565C0"/>
                    <TextBlock Text="Total Tables" FontSize="12" FontWeight="Bold" Foreground="#757575" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" BorderBrush="#E8F5E9" BorderThickness="1.5" CornerRadius="12" Padding="15" Margin="0,0,15,0">
                <StackPanel>
                    <TextBlock Text="{Binding AvailableTables}" FontSize="24" FontWeight="Black" Foreground="#4CAF50"/>
                    <TextBlock Text="Available" FontSize="12" FontWeight="Bold" Foreground="#757575" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" BorderBrush="#FFEBEE" BorderThickness="1.5" CornerRadius="12" Padding="15" Margin="0,0,15,0">
                <StackPanel>
                    <TextBlock Text="{Binding OccupiedTables}" FontSize="24" FontWeight="Black" Foreground="#EF5350"/>
                    <TextBlock Text="Occupied" FontSize="12" FontWeight="Bold" Foreground="#757575" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════════ FILTER BAR ══════════════════ -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Margin="20,10" Padding="15,10" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="Status" FontSize="11" FontWeight="Bold" Foreground="#212121" Margin="4,0,0,4"/>
                    <ComboBox ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding SelectedStatusFilter}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}" Height="38" FontSize="13" Padding="12,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Margin="0,0,15,0">
                    <TextBlock Text="Location" FontSize="11" FontWeight="Bold" Foreground="#212121" Margin="4,0,0,4"/>
                    <ComboBox ItemsSource="{Binding LocationFilters}" SelectedItem="{Binding SelectedLocationFilter}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}" Height="38" FontSize="13" Padding="12,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Margin="0,0,15,0">
                     <TextBlock Text="Search" FontSize="11" FontWeight="Bold" Foreground="#212121" Margin="4,0,0,4"/>
                     <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="38" FontSize="13" Padding="12,0" 
                              materialDesign:HintAssist.Hint="Search tables..."/>
                </StackPanel>
                
                <Button Grid.Column="3" Command="{Binding ClearFiltersCommand}"
                        Content="Clear Filters" VerticalAlignment="Bottom" Height="38" FontSize="11" 
                        Foreground="White" Background="#212121" FontWeight="Bold"
                        materialDesign:ButtonAssist.CornerRadius="6" Margin="0,0,0,1"/>
            </Grid>
        </Border>

        <!-- ══════════════════ TABLES DISPLAY ══════════════════ -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Padding="20,10">
            <ItemsControl ItemsSource="{Binding Tables}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="220" Height="200" Background="White" CornerRadius="12" Margin="0,0,20,20" BorderBrush="#E0E0E0" BorderThickness="1" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Status -->
                                    <RowDefinition Height="*"/>    <!-- Content -->
                                    <RowDefinition Height="Auto"/> <!-- Actions -->
                                </Grid.RowDefinitions>

                                <!-- Status Tag -->
                                <Grid Grid.Row="0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Border Width="8" Height="8" CornerRadius="4" Margin="0,0,8,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#4CAF50"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOccupied}" Value="True">
                                                            <Setter Property="Background" Value="#EF5350"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <TextBlock FontSize="11" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="available"/>
                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOccupied}" Value="True">
                                                            <Setter Property="Text" Value="occupied"/>
                                                            <Setter Property="Foreground" Value="#EF5350"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                    
                                    <TextBlock Text="{Binding Location}" FontSize="10" Foreground="#BDBDBD" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Table Content -->
                                <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,10">
                                    <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Black" Foreground="#212121"/>
                                    <TextBlock Text="{Binding TableNumber}" FontSize="12" Foreground="#757575" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding Capacity, StringFormat='Capacity: {0} people'}" FontSize="11" Foreground="#9E9E9E" Margin="0,12,0,0"/>
                                </StackPanel>

                                <!-- Action Buttons -->
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Button Grid.Column="0" Command="{Binding DataContext.ToggleStatusCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Content="Status" Height="32" Padding="0" FontSize="11" FontWeight="Bold"
                                            Background="#1565C0" Foreground="White" BorderThickness="0"
                                            materialDesign:ButtonAssist.CornerRadius="6" Margin="0,0,6,0"/>
                                    
                                    <Button Grid.Column="1" Command="{Binding DataContext.OpenEditDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Background="#F5F5F5" Foreground="#212121" BorderBrush="#E0E0E0" BorderThickness="1"
                                            Height="32" Padding="0"
                                            materialDesign:ButtonAssist.CornerRadius="6" Margin="0,0,6,0">
                                        <TextBlock Text="Edit" FontSize="11" FontWeight="Bold"/>
                                    </Button>

                                    <Button Grid.Column="2" Command="{Binding DataContext.DeleteTableCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Background="#FFEBEE" Foreground="#EF5350" BorderThickness="0"
                                            Height="32" Padding="0"
                                            materialDesign:ButtonAssist.CornerRadius="6">
                                        <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"/>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ══════════════════ DIALOG OVERLAY ══════════════════ -->
        <Grid Grid.Row="0" Grid.RowSpan="4" Background="#80000000" 
              Visibility="{Binding IsDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="White" Width="380" VerticalAlignment="Center" CornerRadius="12" Padding="30">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,25">
                        <TextBlock Text="Add/Edit Table" FontSize="20" FontWeight="Black" Foreground="#212121"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1">
                        <TextBlock Text="Table Number *" FontSize="11" FontWeight="Bold" Foreground="#212121" Margin="4,0,0,4"/>
                        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding CurrentTable.TableNumber}" Height="40" FontSize="13" 
                                 Padding="12,0" Margin="0,0,0,15" materialDesign:HintAssist.Hint="e.g. Table T-01"/>

                        <TextBlock Text="Table Name *" FontSize="11" FontWeight="Bold" Foreground="#212121" Margin="4,0,0,4"/>
                        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding CurrentTable.Name}" Height="40" FontSize="13" 
                                 Padding="12,0" Margin="0,0,0,15" materialDesign:HintAssist.Hint="e.g. Window Side 1"/>

                        <TextBlock Text="Capacity *" FontSize="11" FontWeight="Bold" Foreground="#212121" Margin="4,0,0,4"/>
                        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding CurrentTable.Capacity}" Height="40" FontSize="13" 
                                 Padding="12,0" Margin="0,0,0,15" materialDesign:HintAssist.Hint="0"/>

                        <TextBlock Text="Location" FontSize="11" FontWeight="Bold" Foreground="#212121" Margin="4,0,0,4"/>
                        <ComboBox ItemsSource="{Binding LocationFilters}" SelectedItem="{Binding CurrentTable.Location}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}" Height="40" FontSize="13" Padding="12,0" Margin="0,0,0,30"/>
                    </StackPanel>

                    <Grid Grid.Row="2" HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding CloseDialogCommand}" Content="Cancel" 
                                    Height="40" Padding="20,0" FontSize="13" FontWeight="Bold" 
                                    Style="{StaticResource MaterialDesignFlatButton}" Foreground="#212121" Margin="0,0,10,0"/>
                            
                            <Button Command="{Binding SaveTableCommand}" Content="Save Table" 
                                    Height="40" Padding="20,0" FontSize="13" FontWeight="Bold" 
                                    Background="#1565C0" Foreground="White" materialDesign:ButtonAssist.CornerRadius="6"
                                    Style="{StaticResource MaterialDesignRaisedButton}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
