<UserControl x:Class="HudiSoftPOS.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1366"
             Background="#F8FAFB">

    <Grid>
        <!-- Main Content -->
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header Card -->
                <RowDefinition Height="Auto"/>  <!-- Filter Strip -->
                <RowDefinition Height="*"/>     <!-- Data Grid -->
            </Grid.RowDefinitions>

            <!-- ═════════════════════════════════════ -->
            <!-- 1. HEADER CARD                       -->
            <!-- ═════════════════════════════════════ -->
            <Border Grid.Row="0" Background="#1B60F5" CornerRadius="16" Padding="28,20" Margin="0,0,0,20">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Users Management" FontSize="28" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Manage system users and permissions" FontSize="14" Foreground="#BBDEFB" Margin="0,5,0,0"/>
                    </StackPanel>
                    <Button Command="{Binding OpenAddUserCommand}" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Height="44" Padding="22,0"
                            Background="White" Foreground="#1B60F5" BorderThickness="0"
                            materialDesign:ButtonAssist.CornerRadius="10"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            FontWeight="Bold" FontSize="14">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountPlus" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="+ Add User" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ═════════════════════════════════════ -->
            <!-- 2. FILTER STRIP                      -->
            <!-- ═════════════════════════════════════ -->
            <Border Grid.Row="1" Background="White" CornerRadius="12" BorderBrush="#E0E0E0" BorderThickness="1" Padding="20,14" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search -->
                    <Border Grid.Column="0" CornerRadius="8" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,16,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" Foreground="#BDBDBD" VerticalAlignment="Center" Margin="12,0"/>
                            <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="14" VerticalAlignment="Center" BorderThickness="0" Background="Transparent"
                                     Foreground="#212121" Padding="5,10"
                                     materialDesign:HintAssist.Hint="Search by name, username or email..."
                                     materialDesign:HintAssist.Foreground="#BDBDBD"/>
                        </Grid>
                    </Border>

                    <!-- Role ComboBox -->
                    <ComboBox Grid.Column="1" ItemsSource="{Binding FilterRoles}" SelectedItem="{Binding SelectedRoleFilter}"
                              Height="44" FontSize="14" Padding="12,0" Margin="0,0,16,0"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Role" BorderBrush="#E0E0E0" Foreground="#212121"/>

                    <!-- Clear Filters -->
                    <Button Grid.Column="2" Command="{Binding ClearFiltersCommand}" Content="Clear Filters"
                            Height="44" Padding="20,0" FontSize="13" FontWeight="SemiBold"
                            Background="#607D8B" Foreground="White" BorderThickness="0"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Style="{StaticResource MaterialDesignRaisedButton}"/>
                </Grid>
            </Border>

            <!-- ═════════════════════════════════════ -->
            <!-- 3. USERS DATA GRID                   -->
            <!-- ═════════════════════════════════════ -->
            <Border Grid.Row="2" Background="White" CornerRadius="16" BorderBrush="#E0E0E0" BorderThickness="1">
                <DataGrid ItemsSource="{Binding Users}" AutoGenerateColumns="False" CanUserAddRows="False"
                          Background="Transparent" BorderThickness="0"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0"
                          RowHeight="56" HeadersVisibility="Column" SelectionMode="Single"
                          IsReadOnly="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FAFAFA"/>
                            <Setter Property="Foreground" Value="#9E9E9E"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="16,14"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F5F8FF"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EBF3FF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>

                        <!-- NAME -->
                        <DataGridTemplateColumn Header="NAME" Width="220" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                                        <Border Width="36" Height="36" CornerRadius="18" Background="#E3F2FD" Margin="0,0,12,0">
                                            <materialDesign:PackIcon Kind="Account" Width="20" Height="20"
                                                                     Foreground="#1B60F5"
                                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding FullName}" Foreground="#212121" FontSize="14"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- USERNAME -->
                        <DataGridTemplateColumn Header="USERNAME" Width="120" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Username}" Foreground="#616161" FontSize="13"
                                               Margin="16,0" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- EMAIL -->
                        <DataGridTemplateColumn Header="EMAIL" Width="*" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Email}" Foreground="#616161" FontSize="13"
                                               Margin="16,0" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- PHONE -->
                        <DataGridTemplateColumn Header="PHONE" Width="130" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Phone}" Foreground="#616161" FontSize="13"
                                               Margin="16,0" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- ROLE -->
                        <DataGridTemplateColumn Header="ROLE" Width="110" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Margin="16,0" CornerRadius="6" Padding="10,5"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E3F2FD"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="admin">
                                                        <Setter Property="Background" Value="#EDE9FE"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="manager">
                                                        <Setter Property="Background" Value="#DCFCE7"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="cashier">
                                                        <Setter Property="Background" Value="#FEF9C3"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="chef">
                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="waiter">
                                                        <Setter Property="Background" Value="#E0F2FE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Role}" FontSize="11" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#1B60F5"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Role}" Value="admin">
                                                            <Setter Property="Foreground" Value="#7C3AED"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Role}" Value="manager">
                                                            <Setter Property="Foreground" Value="#15803D"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Role}" Value="cashier">
                                                            <Setter Property="Foreground" Value="#854D0E"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Role}" Value="chef">
                                                            <Setter Property="Foreground" Value="#B91C1C"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Role}" Value="waiter">
                                                            <Setter Property="Foreground" Value="#0369A1"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- STATUS -->
                        <DataGridTemplateColumn Header="STATUS" Width="110" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Margin="16,0" CornerRadius="6" Padding="10,5"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#DCFCE7"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Deactivated">
                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#15803D"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Deactivated">
                                                                <Setter Property="Fill" Value="#B91C1C"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#15803D"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Deactivated">
                                                                <Setter Property="Foreground" Value="#B91C1C"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- LAST LOGIN -->
                        <DataGridTemplateColumn Header="LAST LOGIN" Width="115" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding LastLogin, StringFormat='{}{0:dd/MM/yyyy}', TargetNullValue='Never'}"
                                               Foreground="#9E9E9E" FontSize="12" Margin="16,0" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- CREATED -->
                        <DataGridTemplateColumn Header="CREATED" Width="105" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding CreatedDate, StringFormat='{}{0:dd/MM/yyyy}'}"
                                               Foreground="#9E9E9E" FontSize="12" Margin="16,0" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- ACTIONS -->
                        <DataGridTemplateColumn Header="ACTIONS" Width="195" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">

                                        <!-- Edit Button - fully wired -->
                                        <Button Command="{Binding DataContext.OpenEditUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Height="30" Padding="12,0" Margin="0,0,6,0"
                                                Background="#EBF3FF" Foreground="#1B60F5" BorderThickness="0"
                                                materialDesign:ButtonAssist.CornerRadius="6"
                                                Style="{StaticResource MaterialDesignFlatButton}"
                                                FontSize="11" FontWeight="Bold">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Pencil" Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock Text="Edit" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- Toggle Status Button -->
                                        <Button Command="{Binding DataContext.ToggleStatusCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Margin="0,0,6,0" Padding="12,0" Height="30">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                    <Setter Property="Foreground" Value="#B91C1C"/>
                                                    <Setter Property="Height" Value="30"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Padding" Value="12,0"/>
                                                    <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="6"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Deactivated">
                                                            <Setter Property="Background" Value="#DCFCE7"/>
                                                            <Setter Property="Foreground" Value="#15803D"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock VerticalAlignment="Center" FontSize="11" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Deactivate"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Deactivated">
                                                                <Setter Property="Text" Value="Activate"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>

                                        <!-- Delete Button -->
                                        <Button Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Width="30" Height="30" Padding="0"
                                                Background="#FEE2E2"
                                                materialDesign:ButtonAssist.CornerRadius="6"
                                                Style="{StaticResource MaterialDesignFlatButton}"
                                                ToolTip="Delete User">
                                            <materialDesign:PackIcon Kind="TrashCanOutline" Width="16" Height="16" Foreground="#B91C1C"/>
                                        </Button>

                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- ADD USER MODAL                                               -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Grid Background="#80000000"
              Visibility="{Binding IsAddUserOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="White" Width="500" CornerRadius="16"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MaxHeight="680" BorderBrush="#E0E0E0" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="Black" Opacity="0.25"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Modal Header -->
                    <Border Grid.Row="0" Padding="28,22,28,18" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Add New User" FontSize="20" FontWeight="Bold" Foreground="#1A1A1A"/>
                                <TextBlock Text="Fill in the details to create a new system account" FontSize="12" Foreground="#9E9E9E" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Command="{Binding CloseAddUserCommand}" HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Style="{StaticResource MaterialDesignIconButton}" Width="36" Height="36" Padding="0">
                                <materialDesign:PackIcon Kind="Close" Width="18" Height="18" Foreground="#9E9E9E"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Form Fields -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="28,20,28,8">

                            <!-- Full Name + Username -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Full Name *" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding NewFullName, UpdateSourceTrigger=PropertyChanged}"
                                             Height="42" FontSize="13" Padding="12,0" VerticalContentAlignment="Center"
                                             materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderBrush="#E0E0E0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Username *" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}"
                                             Height="42" FontSize="13" Padding="12,0" VerticalContentAlignment="Center"
                                             materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderBrush="#E0E0E0"/>
                                </StackPanel>
                            </Grid>

                            <!-- Email -->
                            <TextBlock Text="Email Address" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding NewEmail, UpdateSourceTrigger=PropertyChanged}"
                                     Height="42" FontSize="13" Padding="12,0" VerticalContentAlignment="Center"
                                     materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderBrush="#E0E0E0" Margin="0,0,0,16"/>

                            <!-- Phone + PIN -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Phone Number" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding NewPhone, UpdateSourceTrigger=PropertyChanged}"
                                             Height="42" FontSize="13" Padding="12,0" VerticalContentAlignment="Center"
                                             materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderBrush="#E0E0E0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Quick PIN (4+ digits)" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding NewPin, UpdateSourceTrigger=PropertyChanged}"
                                             Height="42" FontSize="13" Padding="12,0" VerticalContentAlignment="Center"
                                             materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderBrush="#E0E0E0" MaxLength="6"/>
                                </StackPanel>
                            </Grid>

                            <!-- Role -->
                            <TextBlock Text="Role *" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding NewRole}"
                                      Height="42" FontSize="13" Padding="12,0"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}" BorderBrush="#E0E0E0" Margin="0,0,0,16"/>

                            <!-- Address -->
                            <TextBlock Text="Address" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding NewAddress, UpdateSourceTrigger=PropertyChanged}"
                                     Height="64" FontSize="13" Padding="12,10" VerticalContentAlignment="Top"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderBrush="#E0E0E0" Margin="0,0,0,16"/>

                            <!-- Password + Confirm -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Password *" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                                    <PasswordBox x:Name="NewPasswordBox" Height="42" FontSize="13" Padding="12,0"
                                                 materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}" BorderBrush="#E0E0E0"
                                                 PasswordChanged="NewPasswordBox_PasswordChanged"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Confirm Password *" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                                    <PasswordBox x:Name="NewConfirmPasswordBox" Height="42" FontSize="13" Padding="12,0"
                                                 materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}" BorderBrush="#E0E0E0"
                                                 PasswordChanged="NewConfirmPasswordBox_PasswordChanged"/>
                                </StackPanel>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Modal Footer -->
                    <Border Grid.Row="2" Padding="28,16" BorderBrush="#F0F0F0" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Command="{Binding CloseAddUserCommand}" Content="Cancel"
                                    Height="44" Margin="0,0,8,0" FontSize="14" FontWeight="SemiBold"
                                    Background="White" Foreground="#616161" BorderBrush="#E0E0E0"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"/>
                            <Button Grid.Column="1" Command="{Binding SaveUserCommand}" Content="Add New User"
                                    Height="44" Margin="8,0,0,0" FontSize="14" FontWeight="Bold"
                                    Background="#1B60F5" Foreground="White" BorderThickness="0"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    Style="{StaticResource MaterialDesignRaisedButton}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- EDIT USER MODAL                                              -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Grid Background="#80000000"
              Visibility="{Binding IsEditUserOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="White" Width="500" CornerRadius="16"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MaxHeight="620" BorderBrush="#E0E0E0" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="Black" Opacity="0.25"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Modal Header -->
                    <Border Grid.Row="0" Padding="28,22,28,18" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Edit User" FontSize="20" FontWeight="Bold" Foreground="#1A1A1A"/>
                                <TextBlock Text="Update account information below" FontSize="12" Foreground="#9E9E9E" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Command="{Binding CloseEditUserCommand}" HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Style="{StaticResource MaterialDesignIconButton}" Width="36" Height="36" Padding="0">
                                <materialDesign:PackIcon Kind="Close" Width="18" Height="18" Foreground="#9E9E9E"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Edit Form Fields -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="28,20,28,8">

                            <!-- Full Name + Username -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Full Name *" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding EditFullName, UpdateSourceTrigger=PropertyChanged}"
                                             Height="42" FontSize="13" Padding="12,0" VerticalContentAlignment="Center"
                                             materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderBrush="#E0E0E0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Username *" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding EditUsername, UpdateSourceTrigger=PropertyChanged}"
                                             Height="42" FontSize="13" Padding="12,0" VerticalContentAlignment="Center"
                                             materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderBrush="#E0E0E0"/>
                                </StackPanel>
                            </Grid>

                            <!-- Email -->
                            <TextBlock Text="Email Address" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding EditEmail, UpdateSourceTrigger=PropertyChanged}"
                                     Height="42" FontSize="13" Padding="12,0" VerticalContentAlignment="Center"
                                     materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderBrush="#E0E0E0" Margin="0,0,0,16"/>

                            <!-- Phone + PIN -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Phone Number" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding EditPhone, UpdateSourceTrigger=PropertyChanged}"
                                             Height="42" FontSize="13" Padding="12,0" VerticalContentAlignment="Center"
                                             materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderBrush="#E0E0E0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Quick PIN" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding EditPin, UpdateSourceTrigger=PropertyChanged}"
                                             Height="42" FontSize="13" Padding="12,0" VerticalContentAlignment="Center"
                                             materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderBrush="#E0E0E0" MaxLength="6"/>
                                </StackPanel>
                            </Grid>

                            <!-- Role -->
                            <TextBlock Text="Role *" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding EditRole}"
                                      Height="42" FontSize="13" Padding="12,0"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}" BorderBrush="#E0E0E0" Margin="0,0,0,16"/>

                            <!-- Address -->
                            <TextBlock Text="Address" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding EditAddress, UpdateSourceTrigger=PropertyChanged}"
                                     Height="64" FontSize="13" Padding="12,10" VerticalContentAlignment="Top"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderBrush="#E0E0E0" Margin="0,0,0,4"/>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Modal Footer -->
                    <Border Grid.Row="2" Padding="28,16" BorderBrush="#F0F0F0" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Command="{Binding CloseEditUserCommand}" Content="Cancel"
                                    Height="44" Margin="0,0,8,0" FontSize="14" FontWeight="SemiBold"
                                    Background="White" Foreground="#616161" BorderBrush="#E0E0E0"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"/>
                            <Button Grid.Column="1" Command="{Binding SaveEditCommand}" Content="Save Changes"
                                    Height="44" Margin="8,0,0,0" FontSize="14" FontWeight="Bold"
                                    Background="#1B60F5" Foreground="White" BorderThickness="0"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    Style="{StaticResource MaterialDesignRaisedButton}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
