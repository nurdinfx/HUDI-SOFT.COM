<UserControl x:Class="HudiSoftPOS.Views.POSView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:HudiSoftPOS.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1280"
             Background="#F4F6F8">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Category Tab Button Style -->
        <Style x:Key="CatTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="White"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#1565C0"/>
                                <Setter Property="Foreground" Value="#1565C0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- POS Sub-header bar -->
            <RowDefinition Height="*"/>    <!-- Main content -->
        </Grid.RowDefinitions>

        <!-- ══════════════════ POS SUB-HEADER BAR ══════════════════ -->
        <Border Grid.Row="0" Background="#448AFF">
            <Grid Height="48" Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- POS / Orders -->
                    <ColumnDefinition Width="*"/>     <!-- Search -->
                    <ColumnDefinition Width="Auto"/>  <!-- Cashier / Time -->
                </Grid.ColumnDefinitions>

                <!-- Left: POS + Orders link -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="POS" Foreground="White" FontSize="18" FontWeight="Black" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Button Command="{Binding DataContext.NavigateToOrdersCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Background="Transparent" BorderThickness="0" Padding="0" Height="24"
                            Cursor="Hand" Style="{StaticResource MaterialDesignFlatButton}">
                        <TextBlock Text="Orders" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                    </Button>
                </StackPanel>

                <!-- Center: Search bar (Rounded White) -->
                <Border Grid.Column="1" Background="White" CornerRadius="8" Margin="40,6" MaxWidth="600">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" Foreground="#212121" VerticalAlignment="Center" Margin="12,0,4,0"/>
                        <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Background="Transparent"
                                 Foreground="#212121" FontSize="13"
                                 VerticalAlignment="Center" Padding="4,0,10,0"
                                 materialDesign:HintAssist.Hint="Search products by name or barcode..."
                                 materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                 Style="{StaticResource MaterialDesignTextBox}"/>
                    </Grid>
                </Border>

                <!-- Right: Cashier + Time -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#2AFFFFFF" CornerRadius="4" Padding="8,4" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Account" Width="16" Height="16" Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Cashier" Foreground="White" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{Binding CurrentDateTime}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════ MAIN BODY ══════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>    <!-- Products area (Left) -->
                <ColumnDefinition Width="450" MinWidth="380"/>  <!-- Cart panel - responsive -->
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT: Products ─── -->
            <Grid Grid.Column="0" Background="#F4F6F8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Category tabs -->
                    <RowDefinition Height="*"/>    <!-- Product grid -->
                </Grid.RowDefinitions>

                <!-- Category Tabs -->
                <Border Grid.Row="0" Padding="15,10,15,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton Content="{Binding}"
                                                 Style="{StaticResource CatTabStyle}"
                                                 GroupName="POS_CatTabs"
                                                 Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Product Grid (Vertical Cards) -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="15">
                    <ItemsControl ItemsSource="{Binding Products}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="110" Height="160" Margin="0,0,10,10"
                                        Padding="0" BorderThickness="1"
                                        BorderBrush="#E0E0E0" Background="White"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="card" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="8">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <!-- Product Image / Placeholder (Matches Inventory Style) -->
                                                    <Border Margin="8,8,8,4" Background="#F8FAFB" BorderBrush="#F5F5F5" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                                                        <Grid>
                                                            <materialDesign:PackIcon Kind="ImageOutline" Width="30" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#E0E0E0"
                                                                                   Visibility="{Binding ImagePath, Converter={StaticResource InverseStringToVisibilityConverter}}"/>
                                                            <Image Source="{Binding ImagePath}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Visibility="{Binding ImagePath, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                        </Grid>
                                                    </Border>
                                                    <StackPanel Grid.Row="1" Margin="8,0,8,12">
                                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Bold" Foreground="#212121"
                                                                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxHeight="32"/>
                                                        <TextBlock Text="{Binding Price, StringFormat='${0:N2}'}" FontSize="13" FontWeight="Black"
                                                                   Foreground="#212121" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="card" Property="BorderBrush" Value="#1565C0"/>
                                                    <Setter TargetName="card" Property="Background" Value="#F5F5F5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ─── RIGHT: Cart Panel (Precisely like Screenshot) ─── -->
            <Border Grid.Column="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Totals Bar -->
                        <RowDefinition Height="Auto"/> <!-- Barcode box -->
                        <RowDefinition Height="Auto"/> <!-- Cart Headers -->
                        <RowDefinition Height="*"/>    <!-- Cart Items -->
                        <RowDefinition Height="Auto"/> <!-- Footer Controls -->
                    </Grid.RowDefinitions>

                    <!-- Top Bar: Vat | Local | Sub | Total + Orders Button -->
                    <Border Grid.Row="0" Background="#3F51B5" Padding="15,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" MaxWidth="300">
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Vat:" Foreground="#BBDEFB" FontSize="10" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Vat, StringFormat='{}{0:N2}'}" Foreground="White" FontSize="13" FontWeight="Black"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Local:" Foreground="#BBDEFB" FontSize="10" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding LocalAmount, StringFormat='{}{0:N0}'}" Foreground="White" FontSize="13" FontWeight="Black"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Sub:" Foreground="#BBDEFB" FontSize="10" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Subtotal, StringFormat='{}{0:N2}'}" Foreground="White" FontSize="13" FontWeight="Black"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Total:" Foreground="#BBDEFB" FontSize="10" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Total, StringFormat='{}{0:N2}'}" Foreground="White" FontSize="13" FontWeight="Black"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="1" Command="{Binding DataContext.NavigateToOrdersCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Background="#1A237E" Foreground="White" BorderThickness="0"
                                    Height="42" Width="80" FontSize="14" FontWeight="Bold"
                                    materialDesign:ButtonAssist.CornerRadius="6"
                                    Style="{StaticResource MaterialDesignRaisedButton}">
                                <TextBlock Text="Orders"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Barcode Search Box -->
                    <Border Grid.Row="1" Padding="12">
                        <Border BorderBrush="#212121" BorderThickness="1" Background="White" CornerRadius="4">
                            <Grid Height="40">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="Magnify" Width="22" Height="22" Foreground="Black" VerticalAlignment="Center" Margin="10,0,10,0"/>
                                <TextBox Grid.Column="1" Text="{Binding BarcodeQuery, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" VerticalAlignment="Center" FontSize="14"
                                         materialDesign:HintAssist.Hint="Barcode or Product Name"
                                         materialDesign:TextFieldAssist.DecorationVisibility="Hidden"/>
                            </Grid>
                        </Border>
                    </Border>

                    <!-- Cart Table Headers -->
                    <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="0,1,0,1" Padding="12,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>   <!-- Product -->
                                <ColumnDefinition Width="80"/>  <!-- Price -->
                                <ColumnDefinition Width="100"/> <!-- Quantity -->
                                <ColumnDefinition Width="80"/>  <!-- Subtotal -->
                                <ColumnDefinition Width="40"/>  <!-- Action -->
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Product" FontWeight="Bold" FontSize="13" Foreground="Black"/>
                            <TextBlock Grid.Column="1" Text="Price" FontWeight="Bold" FontSize="13" Foreground="Black" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="Quantity" FontWeight="Bold" FontSize="13" Foreground="Black" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="Subtotal" FontWeight="Bold" FontSize="13" Foreground="Black" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <!-- Cart Items List -->
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CartItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="12,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Product Name -->
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="13" FontWeight="Bold" Foreground="Black" 
                                                       TextWrapping="Wrap" MaxWidth="150" VerticalAlignment="Center"/>
                                            
                                            <!-- Price (Underlined like image) -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Price}" FontSize="13" HorizontalAlignment="Center"/>
                                                <Rectangle Height="1" Fill="#212121" Width="40" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            
                                            <!-- Quantity (Rounded Box like image) -->
                                            <Border Grid.Column="2" Width="60" Height="28" BorderBrush="#212121" BorderThickness="1" CornerRadius="6" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Quantity}" FontSize="13" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>
                                            
                                            <!-- Subtotal -->
                                            <TextBlock Grid.Column="3" Text="{Binding Subtotal, StringFormat='${0:N2}'}" FontSize="13" FontWeight="Black" 
                                                       Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                            
                                            <!-- Trash Icon -->
                                            <Button Grid.Column="4" Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" BorderThickness="0" Padding="0" Width="24" Height="24"
                                                    Style="{StaticResource MaterialDesignIconButton}" Foreground="#757575">
                                                <materialDesign:PackIcon Kind="Delete" Width="18" Height="18"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Footer Controls -->
                    <Border Grid.Row="4" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="15">
                        <StackPanel>
                            <!-- Dropdown menus: show on click, close when you click outside -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" ItemsSource="{Binding Rooms}" SelectedItem="{Binding SelectedRoom}"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}" Height="40" Padding="12,0" FontSize="13" Margin="0,0,10,0"
                                          ToolTip="Dropdown: click to open, click outside to close"/>

                                <ComboBox Grid.Column="1" ItemsSource="{Binding Tables}" SelectedItem="{Binding SelectedTable}"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}" Height="40" Padding="12,0" FontSize="13"
                                          materialDesign:HintAssist.Hint="Table: None"
                                          ToolTip="Dropdown: click to open, click outside to close"/>
                            </Grid>

                            <ComboBox ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}" Height="40" Padding="12,0" FontSize="13" Margin="0,0,0,10"
                                      materialDesign:HintAssist.Hint="Customer"
                                      ToolTip="Dropdown: click to open, click outside to close"/>

                            <ComboBox ItemsSource="{Binding Servers}" SelectedItem="{Binding SelectedServer}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}" Height="40" Padding="12,0" FontSize="13" Margin="0,0,0,10"
                                      materialDesign:HintAssist.Hint="Served By"
                                      ToolTip="Dropdown: click to open, click outside to close"/>

                            <!-- Toggle visibility: Discount section (show/hide on toggle) -->
                            <Border Margin="0,0,0,10" Visibility="{Binding IsDiscountSectionVisible, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Discount %" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="1" Text="{Binding DiscountPercent, UpdateSourceTrigger=PropertyChanged}"
                                             Height="36" Padding="8,0" FontSize="14" VerticalContentAlignment="Center"
                                             materialDesign:HintAssist.Hint="e.g. 10 or 5.5"/>
                                    <ToggleButton Grid.Column="2" IsChecked="{Binding IsDiscountPercent, Mode=TwoWay}"
                                                  Content="%" Width="40" Height="28" Margin="8,0,0,0"
                                                  ToolTip="Toggle: % or fixed amount"/>
                                </Grid>
                            </Border>

                            <!-- Note/Ref Box -->
                            <Border BorderBrush="#212121" BorderThickness="1" CornerRadius="4" Margin="0,0,0,12">
                                <TextBox Height="36" BorderThickness="0" Background="Transparent"
                                         FontSize="14" VerticalContentAlignment="Center" Padding="10,0"/>
                            </Border>

                            <!-- Action Buttons Grid -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <!-- Clear -->
                                    <ColumnDefinition Width="Auto"/> <!-- VAT toggle -->
                                    <ColumnDefinition Width="Auto"/> <!-- Discount visibility toggle -->
                                    <ColumnDefinition Width="*"/>    <!-- Create Order button -->
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Command="{Binding ClearCartCommand}"
                                        Background="#EF5350" Foreground="White" BorderThickness="0"
                                        Height="48" Width="85" Content="Clear" FontWeight="Black" FontSize="15"
                                        Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,8,0"
                                        materialDesign:ButtonAssist.CornerRadius="8"/>

                                <!-- Toggle visibility: VAT on/off -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0" ToolTip="Toggle VAT">
                                    <TextBlock Text="VAT" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <ToggleButton IsChecked="{Binding IsVatEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                  Height="22" Width="38" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                </StackPanel>

                                <!-- Toggle visibility: show/hide discount section on click -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Discount" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <ToggleButton IsChecked="{Binding IsDiscountSectionVisible, Mode=TwoWay}"
                                                  Height="22" Width="38" Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                                  ToolTip="Toggle visibility: show/hide discount %"/>
                                </StackPanel>

                                <Button Grid.Column="3" Command="{Binding CreateOrderCommand}"
                                        Background="#1565C0" Foreground="White" BorderThickness="0"
                                        Height="48" Content="Create Order" FontWeight="Bold" FontSize="14"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        materialDesign:ButtonAssist.CornerRadius="8"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
