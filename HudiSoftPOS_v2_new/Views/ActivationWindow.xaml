<Window x:Class="HudiSoftPOS.Views.ActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Software Activation - HUDI SOFT POS" Height="600" Width="450"
        WindowStyle="None" ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Background="#0F172A" AllowsTransparency="True">
    <Border CornerRadius="30" BorderBrush="#1E293B" BorderThickness="1" Background="#0F172A">
        <Grid Margin="40">
            <StackPanel VerticalAlignment="Center">
                <Image Source="/Assets/logo.ico" Width="100" Height="100" Margin="0,0,0,30"/>
                
                <TextBlock Text="HUDI SOFT POS" FontSize="32" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Software License Required" FontSize="16" Foreground="Silver" HorizontalAlignment="Center" Margin="0,5,0,40"/>

                <StackPanel Margin="0,0,0,30">
                    <TextBlock Text="LICENSE KEY" FontSize="12" FontWeight="Bold" Foreground="Silver" Margin="0,0,0,10"/>
                    <TextBox x:Name="LicenseKeyInput" 
                             materialDesign:HintAssist.Hint="XXXX-XXXX-XXXX-XXXX"
                             FontSize="20" FontWeight="Bold" Padding="15"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Foreground="White" BorderBrush="#30FFFFFF"
                             materialDesign:HintAssist.Foreground="Silver"/>
                </StackPanel>

                <Button x:Name="ActivateButton" Content="ACTIVATE SYSTEM" 
                        Height="60" FontSize="18" FontWeight="Black"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#2563EB" Foreground="White"
                        Click="ActivateButton_Click"/>

                <TextBlock x:Name="StatusMessage" Text="" FontSize="14" Foreground="#EF4444" 
                           HorizontalAlignment="Center" Margin="0,20,0,0" TextWrapping="Wrap" TextAlignment="Center"/>

                <StackPanel Margin="0,40,0,0">
                    <TextBlock Text="Don't have a license?" FontSize="14" Foreground="Silver" HorizontalAlignment="Center"/>
                    <Button Content="Request a 3-Day Trial" 
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="#3B82F6" FontWeight="Bold"
                            Click="TrialButton_Click"/>
                </StackPanel>
            </StackPanel>
            
            <Button VerticalAlignment="Top" HorizontalAlignment="Right"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Content="CLOSE" Foreground="Silver" Click="CloseButton_Click"/>
        </Grid>
    </Border>
</Window>
