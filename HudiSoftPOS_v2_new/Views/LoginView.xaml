<Window x:Class="HudiSoftPOS.Views.LoginView"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:HudiSoftPOS.ViewModels"
        mc:Ignorable="d"
        Title="Login - HUDI SOFT POS"
        Icon="pack://application:,,,/Assets/logo.png"
        Height="450" Width="800"
        WindowStyle="None" ResizeMode="CanResizeWithGrip" WindowState="Maximized"
        Background="{DynamicResource MaterialDesignPaper}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" 
                      CornerRadius="0" 
                      GlassFrameThickness="0" 
                      NonClientFrameEdges="None" 
                      ResizeBorderThickness="8" />
    </WindowChrome.WindowChrome>
    
    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Grid>
        <!-- Background Image -->
        <Image Source="pack://application:,,,/Assets/login_bg.jpg" Stretch="UniformToFill">
            <Image.Effect>
                <BlurEffect Radius="5"/>
            </Image.Effect>
        </Image>

        
        <!-- Dark Overlay for readability -->
        <Rectangle Fill="Black" Opacity="0.5"/>

        <!-- Ambient Glow (top-left) -->
        <Ellipse Width="900" Height="700" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-200,-200,0,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#2042A5F5" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Ambient Glow (bottom-right) -->
        <Ellipse Width="700" Height="600" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-150,-150">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#15AB47BC" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        
        <!-- Subtle pattern overlay -->
        <Rectangle Opacity="0.03">
            <Rectangle.Fill>
                <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="White">
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,1,40"/>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>


        <!-- Main Content -->
        <Grid Margin="50,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Branding & Features -->
            <StackPanel VerticalAlignment="Center" Margin="0,0,50,0">
                <Border Background="#25FFFFFF" HorizontalAlignment="Left" CornerRadius="12" Padding="15,4" Margin="0,0,0,30">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="#42A5F5" Margin="0,0,10,0"/>
                        <TextBlock Text="MODERN RESTAURANT SOLUTION" Foreground="White" FontWeight="Bold" FontSize="11" Opacity="0.9"/>
                    </StackPanel>
                </Border>
                
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="HUDI-SOFT" Foreground="White" FontSize="72" FontWeight="Black"/>
                    <TextBlock Text=" POS" Foreground="#42A5F5" FontSize="72" FontWeight="Black" Margin="15,0,0,0"/>
                </StackPanel>
                
                <TextBlock Text="Streamline your operations with our high-performance point of sale system. Designed for speed, reliability, and ease of use." 
                           Foreground="White" FontSize="20" TextWrapping="Wrap" MaxWidth="550" Margin="0,0,0,50" Opacity="0.8" LineHeight="30"/>
                
                <!-- Feature Grid (Glassmorphic) -->
                <UniformGrid Columns="2" MaxWidth="550" HorizontalAlignment="Left">
                    <Border Background="#15FFFFFF" CornerRadius="16" Padding="25" Margin="0,0,15,15" BorderBrush="#20FFFFFF" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Monitor" Foreground="#42A5F5" Width="30" Height="30" VerticalAlignment="Center"/>
                            <StackPanel Margin="15,0,0,0">
                                <TextBlock Text="Smart Terminal" Foreground="White" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="Intuitive touch interface" Foreground="Silver" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Background="#15FFFFFF" CornerRadius="16" Padding="25" Margin="0,0,0,15" BorderBrush="#20FFFFFF" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Security" Foreground="#42A5F5" Width="30" Height="30" VerticalAlignment="Center"/>
                            <StackPanel Margin="15,0,0,0">
                                <TextBlock Text="Secure Access" Foreground="White" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="Multi-factor authentication" Foreground="Silver" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Background="#15FFFFFF" CornerRadius="16" Padding="25" Margin="0,0,15,0" BorderBrush="#20FFFFFF" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ChartBox" Foreground="#42A5F5" Width="30" Height="30" VerticalAlignment="Center"/>
                            <StackPanel Margin="15,0,0,0">
                                <TextBlock Text="Analytics" Foreground="White" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="Real-time sales insights" Foreground="Silver" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Background="#15FFFFFF" CornerRadius="16" Padding="25" Margin="0,0,0,0" BorderBrush="#20FFFFFF" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cloud" Foreground="#42A5F5" Width="30" Height="30" VerticalAlignment="Center"/>
                            <StackPanel Margin="15,0,0,0">
                                <TextBlock Text="Cloud Ready" Foreground="White" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="Sync across all devices" Foreground="Silver" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>

            <!-- Right: Login Panel -->
            <Border Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right"
                    Background="{StaticResource GlassBackgroundBrush}" 
                    Width="480" MaxWidth="500"
                    CornerRadius="40" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1" Padding="0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.5"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Tabs -->
                        <RowDefinition Height="*"/>    <!-- Form -->
                        <RowDefinition Height="Auto"/> <!-- Footer -->
                    </Grid.RowDefinitions>

                    <!-- Tabs -->
                    <Grid Grid.Row="0" Margin="30,40,30,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton Content="Staff Login" IsChecked="{Binding IsStaffLoginVisible, Mode=TwoWay}" GroupName="LoginMode" Style="{StaticResource MaterialDesignTabRadioButton}" 
                                     Foreground="White" FontSize="32" FontWeight="Black" HorizontalContentAlignment="Center" Height="80"/>
                        <RadioButton Grid.Column="1" Content="Quick PIN" IsChecked="{Binding IsPinLoginVisible, Mode=TwoWay}" GroupName="LoginMode" Style="{StaticResource MaterialDesignTabRadioButton}" 
                                     Foreground="White" FontSize="32" FontWeight="Black" HorizontalContentAlignment="Center" Height="80"/>
                        <Rectangle Height="4" Fill="White" VerticalAlignment="Bottom" Margin="10,0" Visibility="{Binding IsStaffLoginVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <Rectangle Grid.Column="1" Height="4" Fill="White" VerticalAlignment="Bottom" Margin="10,0" Visibility="{Binding IsPinLoginVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="40,50">
                        <!-- Logo -->
                        <Border Width="80" Height="80" Background="#15FFFFFF" CornerRadius="16" Margin="0,0,0,25" HorizontalAlignment="Center">
                            <Image Source="pack://application:,,,/Assets/logo.jpg" Stretch="Uniform" Margin="10"/>
                        </Border>
                        
                        <TextBlock Text="HUDI-SOFT" Foreground="White" FontSize="28" FontWeight="Black" HorizontalAlignment="Center"/>
                        <TextBlock Text="SECURE TERMINAL ACCESS" Foreground="Gray" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,40"/>

                        <!-- Staff Login Inputs -->
                        <StackPanel Visibility="{Binding IsStaffLoginVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Margin="0,0,0,20">
                                <materialDesign:PackIcon Kind="Account" Foreground="Gray" Width="20" Height="20" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                <TextBox materialDesign:HintAssist.Hint="USERNAME" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Foreground="White" BorderBrush="#30FFFFFF" BorderThickness="1" 
                                         Padding="45,0,15,0" Height="65" FontSize="14" VerticalContentAlignment="Center"/>
                            </Grid>
                            
                            <Grid Margin="0,0,0,40">
                                <materialDesign:PackIcon Kind="Lock" Foreground="Gray" Width="20" Height="20" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                <PasswordBox materialDesign:HintAssist.Hint="PASSWORD"
                                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                             Foreground="White" BorderBrush="#30FFFFFF" BorderThickness="1" 
                                             Padding="45,0,15,0" Height="65" FontSize="14" VerticalContentAlignment="Center"
                                             PasswordChanged="PasswordBox_PasswordChanged"/>
                                <materialDesign:PackIcon Kind="Eye" Foreground="Gray" Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,15,0"/>
                            </Grid>
                        </StackPanel>

                        <!-- PIN Login Input -->
                        <StackPanel Visibility="{Binding IsPinLoginVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Margin="0,0,0,40">
                                <materialDesign:PackIcon Kind="Numeric" Foreground="Gray" Width="20" Height="20" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                <PasswordBox materialDesign:HintAssist.Hint="ENTER 4-DIGIT PIN"
                                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                             Foreground="White" BorderBrush="#30FFFFFF" BorderThickness="1" 
                                             Padding="45,0,15,0" Height="65" FontSize="24" VerticalContentAlignment="Center"
                                             PasswordChanged="PinBox_PasswordChanged" MaxLength="4"/>
                            </Grid>
                        </StackPanel>

                        <!-- Error Message -->
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF5350" FontSize="14" FontWeight="Bold" 
                                   HorizontalAlignment="Center" Margin="0,0,0,20" TextWrapping="Wrap" TextAlignment="Center"
                                   Visibility="{Binding HasErrorMessage, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <!-- Loading Indicator -->
                        <ProgressBar IsIndeterminate="True" Height="4" Margin="0,0,0,20" 
                                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <Button Content="SIGN IN" Command="{Binding LoginCommand}"
                                Height="70" Background="White" Foreground="#121212" BorderThickness="0"
                                FontSize="20" FontWeight="Black" materialDesign:ButtonAssist.CornerRadius="16"/>
                        
                        <TextBlock Text="SECURE ACCESS • RESTRICTED AREA" Foreground="Gray" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,25,0,0"/>
                    </StackPanel>

                    <!-- Panel Footer -->
                    <Border Grid.Row="2" Background="#10FFFFFF" CornerRadius="0,0,40,40" Padding="30,15">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Fingerprint" Foreground="Gray" Width="16" Height="16" VerticalAlignment="Center"/>
                                <TextBlock Text="ID: HX-0181MLH" Foreground="Gray" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Ellipse Width="8" Height="8" Fill="#00C853" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="SYSTEM READY" Foreground="#00C853" FontSize="10" FontWeight="Black" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Global Footer -->
        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Orientation="Horizontal" Margin="50,0,0,40">
             <materialDesign:PackIcon Kind="Phone" Foreground="#42A5F5" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
             <TextBlock Text="0638326814" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,30,0"/>
             
             <materialDesign:PackIcon Kind="MapMarker" Foreground="#EF5350" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
             <TextBlock Text="ANYWHERE" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>
        
        <TextBlock Text="© 2026 HUDI SYSTEM • SECURE TERMINAL V2.4" Foreground="Silver" FontSize="10" Opacity="0.5"
                    VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,50,40"/>

        <Button Command="{Binding ExitCommand}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="30"
                Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Background="#15FFFFFF" BorderThickness="0" Height="40" Width="40"
                WindowChrome.IsHitTestVisibleInChrome="True">
            <materialDesign:PackIcon Kind="WindowClose" Foreground="White" Width="20" Height="20"/>
        </Button>
    </Grid>
</Window>
